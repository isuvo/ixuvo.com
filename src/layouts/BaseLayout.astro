---
import { profile } from '../lib/profile.js';
import SEO from '../components/SEO.astro';

const {
  title = 'isuvo',
  description = 'Engineering leadership, AI systems, cloud infrastructure, automation, and DevSecOps.',
  canonical,
  image,
  imageAlt,
  type = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd = null,
} = Astro.props;

const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
const privatePath = currentPath === '/write'
  || currentPath.startsWith('/write/')
  || currentPath === '/admin'
  || currentPath.startsWith('/admin/');
const shouldNoindex = noindex || privatePath || Astro.response.status === 404;

function navProps(path: string) {
  const active = path === '/' ? currentPath === '/' : currentPath.startsWith(path);
  return {
    class: active ? 'is-active' : undefined,
    'aria-current': active ? 'page' as const : undefined,
  };
}
---

<!doctype html>
<html lang="en-CA">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KGG1QMLFS6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){
        // eslint-disable-next-line prefer-rest-params -- Google's loader queues variadic commands through arguments.
        window.dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-KGG1QMLFS6');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
          // eslint-disable-next-line prefer-rest-params -- Microsoft Clarity's loader queues calls before its script loads.
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xpoeqlbb5i");
    </script>
    <SEO
      title={title}
      description={description}
      canonical={Astro.response.status === 404 ? null : canonical}
      image={image}
      imageAlt={imageAlt}
      type={type}
      noindex={shouldNoindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      jsonLd={jsonLd}
    />
    <slot name="head" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#050505" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <style is:global>
      :root {
        --bg: #050505;
        --panel: rgba(10, 10, 10, 0.92);
        --panel-strong: #111111;
        --field-bg: #0d0d0d;
        --field-focus: rgba(255, 138, 52, 0.18);
        --line: rgba(255, 255, 255, 0.54);
        --line-soft: rgba(255, 255, 255, 0.14);
        --ink: #f4f3ee;
        --muted: #b7b6ae;
        --accent: #ff8a34;
        --accent-soft: #ffc089;
        --accent-cool: #9eb8bf;
        --accent-contrast: #1a0d03;
        --shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
        --button-surface: rgba(255, 255, 255, 0.055);
        --button-surface-hover: rgba(255, 255, 255, 0.09);
        --heat-0: #121212;
        --heat-1: #256c6a;
        --heat-2: #3f7fb5;
        --heat-3: #ff8a34;
        --heat-4: #ffe082;
        --weight-regular: 400;
        --weight-medium: 500;
        --weight-semibold: 600;
        --weight-bold: 700;
        --font-sans: "Inter", "SF Pro Text", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        --font-display: "IBM Plex Mono", "Courier New", monospace;
      }

      :root[data-theme="light"] {
        --bg: #f7f4ec;
        --panel: rgba(255, 255, 255, 0.88);
        --panel-strong: #ffffff;
        --field-bg: #fffdf8;
        --field-focus: rgba(227, 111, 21, 0.12);
        --line: rgba(40, 40, 40, 0.34);
        --line-soft: rgba(40, 40, 40, 0.12);
        --ink: #111111;
        --muted: #595650;
        --accent: #e36f15;
        --accent-soft: #9f4f10;
        --accent-cool: #305f6e;
        --accent-contrast: #ffffff;
        --shadow: 0 18px 45px rgba(72, 51, 32, 0.11);
        --button-surface: rgba(255, 255, 255, 0.72);
        --button-surface-hover: rgba(255, 255, 255, 0.96);
        --heat-0: #ece3d8;
        --heat-1: #87c9c5;
        --heat-2: #6ea7d7;
        --heat-3: #e36f15;
        --heat-4: #7c4d13;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        font-weight: var(--weight-regular);
        color: var(--ink);
        background: var(--bg);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        overflow-x: clip;
        color: var(--ink);
        background:
          radial-gradient(circle at top center, rgba(255, 138, 52, 0.12), transparent 24%),
          linear-gradient(180deg, #121212 0%, #050505 36%, #000000 100%);
        transition: color 300ms ease, background-color 300ms ease;
      }

      img,
      svg,
      video,
      iframe {
        max-width: 100%;
      }

      section,
      article,
      main {
        min-width: 0;
      }

      :root[data-theme="light"] body {
        background:
          radial-gradient(circle at top center, rgba(227, 111, 21, 0.14), transparent 24%),
          linear-gradient(180deg, #faf6ef 0%, #f5f0e7 36%, #ece4d7 100%);
      }

      a {
        color: inherit;
        overflow-wrap: anywhere;
      }

      p,
      li,
      strong,
      span,
      h1,
      h2,
      h3 {
        overflow-wrap: anywhere;
      }

      .page-shell {
        width: min(1180px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1rem 0 4rem;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 0 1rem;
        border-bottom: 1px solid var(--line);
        transition: border-color 300ms ease;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
      }

      .brand-mark {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 0.75rem;
        border: 1px solid var(--line-soft);
        background: #ffffff;
        padding: 0.35rem;
        object-fit: contain;
      }

      .brand-copy {
        display: grid;
        gap: 0.15rem;
      }

      .brand-copy strong {
        font-size: 1rem;
        font-weight: var(--weight-bold);
        letter-spacing: 0.08em;
      }

      .brand-copy span {
        color: var(--muted);
        font-size: 0.84rem;
        font-weight: var(--weight-regular);
      }

      .nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
        margin-left: auto;
      }

      .nav-toggle {
        display: none;
        align-items: center;
        gap: 0.45rem;
        min-height: 2.75rem;
        border-color: var(--line-soft);
        border-radius: 0.5rem;
        color: var(--ink);
        background: var(--panel);
      }

      .nav a {
        text-decoration: none;
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: var(--weight-medium);
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        min-height: 2.75rem;
      }

      .nav a::before {
        content: "";
        width: 0.55rem;
        height: 0.55rem;
        border: 1px solid var(--accent-soft);
        border-radius: 999px;
        display: inline-block;
      }

      .nav a:hover,
      .nav a:focus-visible,
      .nav a.is-active {
        color: var(--ink);
      }

      .nav a.is-active::before {
        background: var(--accent);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .theme-toggle {
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--line-soft);
        padding: 0.55rem 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-weight: var(--weight-medium);
      }

      .theme-label-compact {
        display: none;
      }

      .theme-toggle::before {
        content: "";
        width: 0.8rem;
        height: 0.8rem;
        border-radius: 999px;
        border: 1px solid currentColor;
        display: inline-block;
      }

      .theme-toggle[data-theme="dark"]::before {
        background: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .theme-toggle[data-theme="light"]::before {
        background: var(--panel-strong);
        border-color: var(--accent);
        box-shadow:
          inset 0 0 0 3px var(--accent),
          0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .hero {
        padding: clamp(2.2rem, 7vw, 5.5rem) 0 clamp(2rem, 5vw, 3.5rem);
        text-align: center;
        border-bottom: 1px solid var(--line);
      }

      h1, h2, h3 {
        font-family: var(--font-display);
        line-height: 1.12;
        margin: 0;
        font-weight: var(--weight-bold);
      }

      h1 {
        font-size: clamp(2.1rem, 5vw, 3.5rem);
        letter-spacing: 0.04em;
      }

      .hero-statement {
        position: relative;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0 0.32em;
        padding-bottom: 0.3rem;
      }

      .hero-statement::before {
        content: "";
        position: absolute;
        left: 50%;
        top: -0.65rem;
        width: clamp(10rem, 32vw, 22rem);
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--line), var(--accent), var(--line), transparent);
        opacity: 0;
        transform: translateX(-50%) scaleX(0);
        animation: hero-structure-trace 900ms 250ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .hero-statement::after {
        content: "";
        position: absolute;
        left: 50%;
        bottom: -0.1rem;
        width: clamp(4rem, 12vw, 8rem);
        height: 2px;
        background: linear-gradient(90deg, var(--accent), var(--accent-soft));
        border-radius: 999px;
        opacity: 0;
        transform: translateX(-50%) scaleX(0);
        box-shadow: 0 0 1rem color-mix(in srgb, var(--accent) 32%, transparent);
        animation: hero-accent-sweep 760ms 520ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .hero-phrase {
        display: inline-block;
        opacity: 0;
        clip-path: inset(0 0 100% 0);
        transform: translateY(0.45em);
        animation: hero-phrase-reveal 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .hero-architecting {
        animation-delay: 60ms;
      }

      .hero-agentic {
        color: var(--accent-soft);
        animation-delay: 180ms;
      }

      .hero-support,
      .hero-lead,
      .hero-actions-intro {
        opacity: 0;
        transform: translateY(0.55rem);
        animation: hero-copy-in 620ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .hero-support { animation-delay: 500ms; }
      .hero-lead { animation-delay: 640ms; }
      .hero-actions-intro { animation-delay: 780ms; }

      @keyframes hero-phrase-reveal {
        from {
          opacity: 0;
          clip-path: inset(0 0 100% 0);
          transform: translateY(0.45em);
        }
        to {
          opacity: 1;
          clip-path: inset(0);
          transform: translateY(0);
        }
      }

      @keyframes hero-copy-in {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes hero-structure-trace {
        40% { opacity: 0.7; }
        to {
          opacity: 0.7;
          transform: translateX(-50%) scaleX(1);
        }
      }

      @keyframes hero-accent-sweep {
        45% { opacity: 1; }
        to {
          opacity: 1;
          transform: translateX(-50%) scaleX(1);
        }
      }

      h2 {
        font-size: 1.5rem;
      }

      p {
        line-height: 1.65;
        color: var(--muted);
        font-weight: var(--weight-regular);
        margin: 0;
      }

      .eyebrow,
      .meta {
        font-family: var(--font-display);
        color: var(--accent-soft);
        letter-spacing: 0.06em;
        font-size: 0.78rem;
        font-weight: var(--weight-semibold);
        text-transform: uppercase;
      }

      .section {
        padding: clamp(1.6rem, 4vw, 2.8rem) 0;
        border-bottom: 1px solid var(--line);
      }

      .section-head {
        text-align: center;
        margin-bottom: 1rem;
      }

      .section-title {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.55rem;
      }

      .section-icon {
        width: 1rem;
        height: 1rem;
        border-radius: 0.25rem;
        background: linear-gradient(135deg, var(--accent), var(--accent-soft));
        display: inline-block;
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .grid {
        display: grid;
        gap: 1.2rem;
      }

      .grid.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .grid.three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .panel,
      .post-card,
      .summary-card,
      .activity-shell,
      .timeline-card {
        background: var(--panel);
        border: 1px solid var(--line-soft);
        padding: 1.1rem;
        border-radius: 0.7rem;
        box-shadow: var(--shadow);
        transition: color 300ms ease, border-color 300ms ease, background-color 300ms ease, transform 180ms ease;
      }

      .post-card,
      .panel,
      .summary-card,
      .timeline-card {
        min-width: 0;
      }

      .post-card {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
      }

      .hero-actions,
      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
      }

      .hero-actions {
        justify-content: center;
        gap: 0.7rem;
        margin-top: 1.2rem;
      }

      .pill {
        color: var(--ink);
        font-size: 0.88rem;
        font-weight: var(--weight-medium);
        white-space: nowrap;
      }

      .pill::before {
        content: "+";
        color: var(--accent);
        margin-right: 0.35rem;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.65rem;
        min-width: 10.25rem;
        min-height: 2.85rem;
        text-decoration: none;
        border: 1px solid rgba(255, 138, 52, 0.72);
        border-radius: 0.6rem;
        padding: 0.72rem 1.05rem;
        color: var(--ink);
        background:
          linear-gradient(135deg, rgba(255, 138, 52, 0.16), rgba(255, 138, 52, 0.04)),
          var(--button-surface);
        font-family: var(--font-display);
        font-weight: var(--weight-semibold);
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.16);
        backdrop-filter: blur(8px);
        transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease, background-color 160ms ease;
      }

      .cta:hover,
      .cta:focus-visible {
        transform: translateY(-2px);
        border-color: var(--accent);
        background-color: rgba(255, 138, 52, 0.18);
        box-shadow: 0 12px 30px rgba(255, 138, 52, 0.2);
        outline: none;
      }

      .cta.cta-secondary {
        color: var(--ink);
        border-color: var(--line-soft);
        background: var(--button-surface);
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.12);
      }

      .cta.cta-secondary:hover,
      .cta.cta-secondary:focus-visible {
        border-color: var(--accent-soft);
        background: var(--button-surface-hover);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
      }

      .cta-icon {
        color: var(--accent);
        font-size: 1.05rem;
        line-height: 1;
        transition: transform 160ms ease;
      }

      .cta:hover .cta-icon,
      .cta:focus-visible .cta-icon {
        transform: translateX(0.18rem);
      }

      .cta-download:hover .cta-icon,
      .cta-download:focus-visible .cta-icon {
        transform: translateY(0.16rem);
      }

      .lead-copy {
        max-width: 56rem;
        margin: 0.85rem auto 0;
      }

      .identity-lines {
        display: grid;
        gap: 0.35rem;
        margin-top: 0.9rem;
      }

      .identity-primary {
        font-size: clamp(1.02rem, 2vw, 1.22rem);
        color: var(--ink);
        font-weight: var(--weight-semibold);
      }

      .identity-name {
        color: var(--accent-soft);
        font-weight: var(--weight-bold);
      }

      .identity-focus {
        color: var(--muted);
        font-size: clamp(0.95rem, 1.7vw, 1.08rem);
        font-weight: var(--weight-medium);
        letter-spacing: 0.01em;
      }

      .identity-focus span {
        color: var(--accent);
        margin-inline: 0.18rem;
      }

      .section-title a {
        color: var(--ink);
        text-decoration-color: var(--accent-soft);
        text-underline-offset: 0.18rem;
      }

      .activity-grid {
        display: grid;
        grid-template-columns: repeat(53, minmax(10px, 1fr));
        grid-template-rows: repeat(7, auto);
        gap: 3px;
        grid-auto-flow: column;
        width: 100%;
        min-width: 686px;
        padding-bottom: 0.35rem;
      }

      .activity-shell {
        min-width: 0;
        overflow: hidden;
        width: 100%;
      }

      .activity-scroll {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 0.2rem;
        overscroll-behavior-inline: contain;
        scrollbar-gutter: stable;
        -webkit-overflow-scrolling: touch;
      }

      .activity-cell {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 2px;
        background: var(--heat-0);
      }

      .activity-cell.level-1 { background: var(--heat-1); }
      .activity-cell.level-2 { background: var(--heat-2); }
      .activity-cell.level-3 { background: var(--heat-3); }
      .activity-cell.level-4 { background: var(--heat-4); }

      .activity-months {
        display: grid;
        grid-template-columns: repeat(53, minmax(10px, 1fr));
        gap: 3px;
        width: 100%;
        min-width: 686px;
        color: var(--muted);
        font-size: 0.8rem;
        margin-bottom: 0.55rem;
      }

      .activity-months span {
        white-space: nowrap;
      }

      .summary-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
      }

      .summary-card strong,
      .post-card h3,
      .panel h3 {
        display: block;
        margin-bottom: 0.2rem;
        color: var(--ink);
        font-size: 1rem;
      }

      .post-card h3 {
        font-family: var(--font-sans);
        font-weight: var(--weight-semibold);
        line-height: 1.35;
        letter-spacing: 0;
      }

      .post-card p {
        font-family: var(--font-sans);
        font-weight: var(--weight-regular);
      }

      .summary-card strong,
      .post-card h3,
      .panel h3,
      .entry-title {
        font-weight: var(--weight-semibold);
      }

      .metric-value {
        font-weight: var(--weight-bold);
      }

      .summary-card p {
        margin-top: 0.35rem;
      }

      .metric-value {
        display: block;
        font-size: 1.4rem;
        color: var(--ink);
        margin-bottom: 0.25rem;
      }

      .three-col-list {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.2rem;
      }

      .timeline-stack {
        position: relative;
        display: grid;
        gap: 1rem;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
      }

      .timeline-stack::before {
        content: "";
        position: absolute;
        left: 0.45rem;
        top: 0.35rem;
        bottom: 0.35rem;
        width: 2px;
        background: linear-gradient(180deg, var(--accent-soft), rgba(255, 138, 52, 0.16));
      }

      .timeline-card {
        position: relative;
        padding: 1.2rem 1.2rem 1.2rem 1.4rem;
        background:
          linear-gradient(135deg, rgba(255, 138, 52, 0.08), transparent 26%),
          var(--panel);
      }

      .timeline-card::before {
        content: "";
        position: absolute;
        left: -1.34rem;
        top: 1.2rem;
        width: 0.85rem;
        height: 0.85rem;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 6px rgba(255, 138, 52, 0.12);
      }

      .timeline-period {
        color: var(--accent-soft);
        font-size: 0.8rem;
        font-family: var(--font-display);
        font-weight: var(--weight-semibold);
        margin-bottom: 0.55rem;
        letter-spacing: 0.04em;
      }

      .timeline-detail {
        margin-top: 0.5rem;
      }

      .timeline-points {
        margin: 0.75rem 0 0;
        padding-left: 1.05rem;
        display: grid;
        gap: 0.45rem;
      }

      .timeline-points li {
        color: var(--muted);
      }

      .entry-title {
        color: var(--ink);
        font-size: 1.05rem;
        margin-bottom: 0.35rem;
      }

      .entry-subtitle {
        color: var(--muted);
        margin-bottom: 0.6rem;
        font-size: 0.92rem;
      }

      .post-card a,
      .entry-link {
        text-decoration: none;
      }

      .home-post-card h3 a {
        display: inline;
        color: var(--ink);
        text-decoration: none;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.2rem;
        transition: color 160ms ease, text-decoration-color 160ms ease;
      }

      .home-post-card h3 a::after {
        content: " \2192";
        display: inline-block;
        color: var(--accent);
        font-weight: var(--weight-semibold);
        text-decoration: none;
        opacity: 0;
        transform: translateX(-0.12rem);
        transition: opacity 160ms ease, transform 160ms ease;
      }

      .home-post-card h3 a:hover,
      .home-post-card h3 a:focus-visible {
        color: var(--accent-soft);
        text-decoration: underline;
        text-decoration-color: var(--accent);
        outline: none;
      }

      .home-post-card h3 a:hover::after,
      .home-post-card h3 a:focus-visible::after {
        opacity: 1;
        transform: translateX(0.22rem);
      }

      .post-card .meta,
      .repo-card .meta {
        color: var(--muted);
        margin-bottom: 0.25rem;
        font-family: var(--font-sans);
        font-weight: var(--weight-medium);
        letter-spacing: 0.01em;
      }

      .repo-card {
        position: relative;
        gap: 0.75rem;
        min-height: 16.25rem;
        background:
          linear-gradient(180deg, rgba(255, 138, 52, 0.08), transparent 26%),
          var(--panel);
      }

      .repo-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent-cool));
      }

      .repo-card h3 {
        font-size: 1.08rem;
      }

      .repo-card p {
        font-family: var(--font-sans);
        font-size: 0.95rem;
        font-weight: var(--weight-regular);
        line-height: 1.65;
      }

      .repo-card h3 a {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: transparent;
        text-underline-offset: 0.18rem;
      }

      .repo-card h3 a:hover,
      .repo-card h3 a:focus-visible {
        color: var(--accent-soft);
        text-decoration-color: currentColor;
        outline: none;
      }

      .repo-card p {
        flex: 1 1 auto;
      }

      .repo-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: auto;
        padding-top: 0.4rem;
      }

      .repo-action {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border: 1px solid var(--line-soft);
        color: var(--ink);
        padding: 0.55rem 0.72rem;
        font-size: 0.86rem;
        font-weight: var(--weight-medium);
        line-height: 1;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.03);
      }

      .repo-action::before {
        content: "";
        width: 0.48rem;
        height: 0.48rem;
        border-radius: 999px;
        border: 1px solid currentColor;
      }

      .repo-action.is-primary {
        border-color: rgba(255, 138, 52, 0.56);
        background: rgba(255, 138, 52, 0.12);
        color: var(--accent-soft);
      }

      .repo-action:hover,
      .repo-action:focus-visible {
        border-color: var(--accent);
        color: var(--accent-soft);
        outline: none;
      }

      .legacy-note {
        color: var(--accent-soft);
        margin-top: 0.2rem;
      }

      .cover-image {
        width: 100%;
        height: auto;
        object-fit: cover;
        background:
          radial-gradient(circle at top right, rgba(255, 138, 52, 0.12), transparent 34%),
          var(--panel-strong);
        border: 1px solid var(--line-soft);
        margin: 0.85rem 0 1rem;
        display: block;
      }

      .contact-card {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        width: 100%;
      }

      .contact-card .contact-item {
        min-width: 0;
        flex: 1 1 12rem;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        justify-content: center;
      }

      .contact-card strong {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--ink);
        margin: 0;
        font-size: 0.95rem;
        font-weight: var(--weight-semibold);
      }

      .contact-card strong::before {
        content: "";
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 0.2rem;
        background: linear-gradient(135deg, var(--accent), var(--accent-soft));
        display: inline-block;
      }

      .contact-card p {
        margin: 0;
      }

      .tool-group-head {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 0.2rem;
      }

      .tool-icon {
        width: 1.8rem;
        height: 1.8rem;
        border-radius: 0.45rem;
        border: 1px solid var(--line-soft);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-soft);
        font-size: 0.78rem;
        background: rgba(255, 138, 52, 0.08);
        flex: 0 0 auto;
      }

      footer {
        margin-top: 2.5rem;
        color: var(--muted);
        font-size: 0.92rem;
        text-align: center;
      }

      .back-to-top {
        position: fixed;
        right: 1.25rem;
        bottom: 1.25rem;
        width: 2.75rem;
        height: 2.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border-color: var(--line);
        background:
          linear-gradient(135deg, rgba(255, 138, 52, 0.2), transparent 60%),
          var(--panel-strong);
        color: var(--ink);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.1);
        opacity: 0;
        pointer-events: none;
        transform: translateY(0.6rem);
        transition:
          opacity 160ms ease,
          transform 160ms ease,
          border-color 160ms ease;
        z-index: 30;
      }

      .back-to-top.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .back-to-top:hover,
      .back-to-top:focus-visible {
        border-color: var(--accent);
        outline: none;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
      }

      label {
        display: grid;
        gap: 0.4rem;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: var(--weight-semibold);
      }

      input,
      textarea,
      select,
      button {
        font: inherit;
      }

      input,
      textarea,
      select {
        width: 100%;
        background: var(--field-bg);
        color: var(--ink);
        border: 1px solid var(--line-soft);
        padding: 0.7rem 0.8rem;
      }

      input::placeholder,
      textarea::placeholder {
        color: var(--muted);
      }

      textarea {
        min-height: 10rem;
        resize: vertical;
      }

      input:focus,
      textarea:focus,
      select:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 0.18rem var(--field-focus);
      }

      button {
        background: transparent;
        color: var(--ink);
        border: 1px solid var(--line);
        padding: 0.7rem 1rem;
        cursor: pointer;
        border-radius: 0.45rem;
        transition: color 160ms ease, background-color 160ms ease, border-color 160ms ease, transform 160ms ease;
      }

      button:hover:not(:disabled),
      button:focus-visible {
        border-color: var(--accent);
        background-color: rgba(255, 138, 52, 0.1);
        outline: none;
      }

      button[aria-busy="true"] {
        cursor: wait;
        opacity: 0.72;
      }

      button[aria-busy="true"]::after {
        content: "";
        width: 0.75rem;
        height: 0.75rem;
        margin-left: 0.45rem;
        border: 2px solid currentColor;
        border-top-color: transparent;
        border-radius: 999px;
        display: inline-block;
        animation: spin 0.8s linear infinite;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .danger-button {
        border-color: rgba(255, 138, 52, 0.45);
        color: var(--accent-soft);
      }

      .helper {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .status-line {
        color: var(--accent-cool);
      }

      .post-content {
        font-size: 1rem;
        line-height: 1.6;
      }

      .post-content h2,
      .post-content h3 {
        margin-top: 1.8rem;
        margin-bottom: 0.6rem;
      }

      .post-content p,
      .post-content li {
        color: var(--ink);
        line-height: 1.6;
        margin-bottom: 0.8rem;
      }

      .post-content pre,
      .post-content blockquote {
        border: 1px solid var(--line-soft);
        padding: 0.9rem;
        overflow-x: auto;
      }

      .post-content pre {
        background: rgba(0, 0, 0, 0.28);
      }

      :root[data-theme="light"] .post-content pre {
        background: rgba(17, 17, 17, 0.05);
      }

      .post-content code {
        font-family: var(--font-display);
        font-size: 0.94em;
      }

      .post-content :not(pre) > code {
        background: rgba(255, 138, 52, 0.12);
        border: 1px solid var(--line-soft);
        padding: 0.12rem 0.35rem;
      }

      .post-content pre code {
        display: block;
        white-space: pre;
        min-width: max-content;
        color: var(--ink);
      }

      .post-content img,
      .post-content figure img {
        display: block;
        max-width: 100% !important;
        height: auto !important;
        margin: 1rem auto;
        border: 1px solid var(--line-soft);
      }

      .post-content figure,
      .post-content .wp-block-image {
        max-width: 100%;
        margin: 1rem 0;
        overflow: hidden;
      }

      .post-content table {
        display: block;
        width: 100%;
        overflow-x: auto;
        border-collapse: collapse;
        margin: 1rem 0;
      }

      .post-content th,
      .post-content td {
        border: 1px solid var(--line-soft);
        padding: 0.55rem 0.7rem;
        text-align: left;
      }

      .post-content ul,
      .post-content ol {
        padding-left: 1.2rem;
      }

      @media (max-width: 1100px) {
        .contact-card,
        .grid.three,
        .three-col-list,
        .summary-strip,
        .form-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 820px) {
        .grid.two {
          grid-template-columns: 1fr;
        }

        .topbar {
          align-items: center;
          flex-direction: row;
          flex-wrap: wrap;
        }

        .nav-toggle {
          display: inline-flex;
          order: 3;
        }

        .nav {
          order: 4;
          width: 100%;
          margin-left: 0;
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 0.45rem;
          padding: 0.55rem 0 0.2rem;
        }

        .js .nav:not(.is-open) {
          display: none;
        }

        .nav a {
          width: 100%;
          min-height: 2.9rem;
          padding: 0.65rem 0.75rem;
          border: 1px solid var(--line-soft);
          border-radius: 0.45rem;
          background: var(--panel);
        }

        .topbar > .theme-toggle {
          order: 2;
          margin-left: auto;
          min-height: 2.75rem;
        }

        .theme-label-full {
          display: none;
        }

        .theme-label-compact {
          display: inline;
        }

        .activity-scroll {
          margin-inline: 0;
        }

        .back-to-top {
          right: 0.9rem;
          bottom: 0.9rem;
          width: 2.45rem;
          height: 2.45rem;
        }
      }

      @media (max-width: 480px) {
        .page-shell {
          width: min(100% - 1.2rem, 1180px);
        }

        .brand-copy span {
          display: none;
        }

        .brand-mark {
          width: 2.8rem;
          height: 2.8rem;
        }

        .nav {
          grid-template-columns: 1fr;
        }

        .hero-actions .cta {
          width: 100%;
          justify-content: center;
        }

        .hero-statement {
          gap: 0.08em 0.28em;
        }

        .hero-phrase {
          max-width: 100%;
        }

        .contact-card .contact-item {
          flex: 1 1 100%;
          flex-wrap: nowrap;
        }

        .contact-card .contact-item:first-child p,
        .contact-card .contact-item:first-child a {
          white-space: nowrap;
          overflow-wrap: normal;
          word-break: normal;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          scroll-behavior: auto !important;
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <img class="brand-mark" src="/logo.png" alt="isuvo logo" />
          <span class="brand-copy">
            <strong>{profile.shortName}</strong>
            <span>{profile.subtitle}</span>
          </span>
        </a>
        <nav class="nav" id="primary-nav" aria-label="Primary">
          <a href="/" {...navProps('/')}>Home</a>
          <a href="/blog" {...navProps('/blog')}>Blog</a>
          <a href="/write" {...navProps('/write')}>Write</a>
          <a href={profile.links.resume} target="_blank" rel="noreferrer">Resume</a>
        </nav>
        <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Change color theme">
          <span class="theme-label-full">Theme</span>
          <span class="theme-label-compact" aria-hidden="true">Theme</span>
        </button>
        <button type="button" id="nav-toggle" class="nav-toggle" aria-expanded="false" aria-controls="primary-nav">
          <span aria-hidden="true">&#9776;</span> Menu
        </button>
      </header>
      <slot />
      <footer>
        &copy; {year} isuvo. For professional inquiries, contact <a href="mailto:admin@ixuvo.com">admin@ixuvo.com</a>.
      </footer>
    </div>
    <button type="button" id="back-to-top" class="back-to-top" aria-label="Back to top">↑</button>
    <script is:inline>
      const storageKey = 'isuvo_theme';
      const root = document.documentElement;
      const toggle = document.getElementById('theme-toggle');
      const fullThemeLabel = toggle?.querySelector('.theme-label-full');
      const compactThemeLabel = toggle?.querySelector('.theme-label-compact');
      const navToggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('primary-nav');
      const backToTop = document.getElementById('back-to-top');

      function applyTheme(theme) {
        root.setAttribute('data-theme', theme);
        if (toggle) {
          const nextTheme = theme === 'light' ? 'Dark' : 'Light';
          if (fullThemeLabel) fullThemeLabel.textContent = `${nextTheme} Mode`;
          if (compactThemeLabel) compactThemeLabel.textContent = nextTheme;
          toggle.setAttribute('aria-label', `Switch to ${nextTheme.toLowerCase()} mode`);
          toggle.dataset.theme = theme;
          toggle.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
        }
      }

      const storedTheme = localStorage.getItem(storageKey);
      applyTheme(storedTheme || 'dark');

      toggle?.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        localStorage.setItem(storageKey, next);
        applyTheme(next);
      });

      function setNavOpen(open) {
        nav?.classList.toggle('is-open', open);
        navToggle?.setAttribute('aria-expanded', String(open));
      }

      navToggle?.addEventListener('click', () => {
        setNavOpen(navToggle.getAttribute('aria-expanded') !== 'true');
      });

      nav?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setNavOpen(false));
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setNavOpen(false);
          navToggle?.focus();
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 820) setNavOpen(false);
      }, { passive: true });

      function updateBackToTop() {
        backToTop?.classList.toggle('is-visible', window.scrollY > 420);
      }

      window.addEventListener('scroll', updateBackToTop, { passive: true });
      updateBackToTop();

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
