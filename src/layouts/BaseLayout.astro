---
const {
  title = 'isuvo',
  description = 'Local-first personal site and publishing system.',
} = Astro.props;
import { profile } from '../lib/profile.js';

const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();

function navProps(path) {
  const active = path === '/' ? currentPath === '/' : currentPath.startsWith(path);
  return {
    class: active ? 'is-active' : undefined,
    'aria-current': active ? 'page' : undefined,
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <style is:global>
      :root {
        --bg: #050505;
        --panel: rgba(10, 10, 10, 0.92);
        --panel-strong: #111111;
        --field-bg: #0d0d0d;
        --field-focus: rgba(255, 138, 52, 0.18);
        --line: rgba(255, 255, 255, 0.54);
        --line-soft: rgba(255, 255, 255, 0.14);
        --ink: #f4f3ee;
        --muted: #b7b6ae;
        --accent: #ff8a34;
        --accent-soft: #ffc089;
        --accent-cool: #9eb8bf;
        --heat-0: #121212;
        --heat-1: #256c6a;
        --heat-2: #3f7fb5;
        --heat-3: #ff8a34;
        --heat-4: #ffe082;
      }

      :root[data-theme="light"] {
        --bg: #f7f4ec;
        --panel: rgba(255, 255, 255, 0.88);
        --panel-strong: #ffffff;
        --field-bg: #fffdf8;
        --field-focus: rgba(227, 111, 21, 0.12);
        --line: rgba(40, 40, 40, 0.34);
        --line-soft: rgba(40, 40, 40, 0.12);
        --ink: #111111;
        --muted: #595650;
        --accent: #e36f15;
        --accent-soft: #9f4f10;
        --accent-cool: #305f6e;
        --heat-0: #ece3d8;
        --heat-1: #87c9c5;
        --heat-2: #6ea7d7;
        --heat-3: #e36f15;
        --heat-4: #7c4d13;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "IBM Plex Mono", "Courier New", monospace;
        color: var(--ink);
        background: var(--bg);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top center, rgba(255, 138, 52, 0.12), transparent 24%),
          linear-gradient(180deg, #121212 0%, #050505 36%, #000000 100%);
      }

      :root[data-theme="light"] body {
        background:
          radial-gradient(circle at top center, rgba(227, 111, 21, 0.14), transparent 24%),
          linear-gradient(180deg, #faf6ef 0%, #f5f0e7 36%, #ece4d7 100%);
      }

      a {
        color: inherit;
        overflow-wrap: anywhere;
      }

      p,
      li,
      strong,
      span,
      h1,
      h2,
      h3 {
        overflow-wrap: anywhere;
      }

      .page-shell {
        width: min(1180px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1rem 0 4rem;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 0 1rem;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
      }

      .brand-mark {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 0.75rem;
        border: 1px solid var(--line-soft);
        background: #ffffff;
        padding: 0.35rem;
        object-fit: contain;
      }

      .brand-copy {
        display: grid;
        gap: 0.15rem;
      }

      .brand-copy strong {
        font-size: 1rem;
        letter-spacing: 0.08em;
      }

      .brand-copy span {
        color: var(--muted);
        font-size: 0.84rem;
      }

      .nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
      }

      .nav a {
        text-decoration: none;
        color: var(--muted);
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
      }

      .nav a::before {
        content: "";
        width: 0.55rem;
        height: 0.55rem;
        border: 1px solid var(--accent-soft);
        border-radius: 999px;
        display: inline-block;
      }

      .nav a:hover,
      .nav a:focus-visible,
      .nav a.is-active {
        color: var(--ink);
      }

      .nav a.is-active::before {
        background: var(--accent);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .theme-toggle {
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--line-soft);
        padding: 0.55rem 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
      }

      .theme-toggle::before {
        content: "";
        width: 0.8rem;
        height: 0.8rem;
        border-radius: 999px;
        border: 1px solid currentColor;
        display: inline-block;
      }

      .theme-toggle[data-theme="dark"]::before {
        background: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .theme-toggle[data-theme="light"]::before {
        background: var(--panel-strong);
        border-color: var(--accent);
        box-shadow:
          inset 0 0 0 3px var(--accent),
          0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .hero {
        padding: 1.5rem 0 1.2rem;
        text-align: center;
        border-bottom: 1px solid var(--line);
      }

      h1, h2, h3 {
        line-height: 1.12;
        margin: 0;
        font-weight: 700;
      }

      h1 {
        font-size: clamp(2.1rem, 5vw, 3.5rem);
        letter-spacing: 0.04em;
      }

      h2 {
        font-size: 1.5rem;
      }

      p {
        line-height: 1.65;
        color: var(--muted);
        margin: 0;
      }

      .eyebrow,
      .meta {
        color: var(--accent-soft);
        letter-spacing: 0.06em;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
      }

      .section {
        padding: 1rem 0 0;
        border-bottom: 1px solid var(--line);
      }

      .section-head {
        text-align: center;
        margin-bottom: 1rem;
      }

      .section-title {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.55rem;
      }

      .section-icon {
        width: 1rem;
        height: 1rem;
        border-radius: 0.25rem;
        background: linear-gradient(135deg, var(--accent), var(--accent-soft));
        display: inline-block;
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .grid {
        display: grid;
        gap: 1.2rem;
      }

      .grid.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .grid.three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .panel,
      .post-card,
      .summary-card,
      .activity-shell,
      .timeline-card {
        background: var(--panel);
        border: 1px solid var(--line-soft);
        padding: 1.1rem;
      }

      .post-card,
      .panel,
      .summary-card,
      .timeline-card {
        min-width: 0;
      }

      .post-card {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
      }

      .hero-actions,
      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
      }

      .hero-actions {
        justify-content: center;
        margin-top: 1rem;
      }

      .pill {
        color: var(--ink);
        font-size: 0.88rem;
        white-space: nowrap;
      }

      .pill::before {
        content: "+";
        color: var(--accent);
        margin-right: 0.35rem;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        border: 1px solid var(--line);
        padding: 0.65rem 0.9rem;
      }

      .cta::before {
        content: "";
        width: 0.6rem;
        height: 0.6rem;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.12);
      }

      .lead-copy {
        max-width: 56rem;
        margin: 0.85rem auto 0;
      }

      .identity-lines {
        margin-top: 0.75rem;
      }

      .identity-lines div {
        font-size: clamp(1rem, 2vw, 1.3rem);
        color: var(--ink);
        font-weight: 700;
      }

      .section-title a {
        color: var(--ink);
        text-decoration-color: var(--accent-soft);
        text-underline-offset: 0.18rem;
      }

      .activity-grid {
        display: grid;
        grid-template-columns: repeat(53, minmax(10px, 1fr));
        grid-template-rows: repeat(7, auto);
        gap: 3px;
        grid-auto-flow: column;
        min-width: 686px;
        width: 100%;
        padding-bottom: 0.35rem;
      }

      .activity-shell {
        min-width: 0;
        overflow: hidden;
        width: 100%;
      }

      .activity-scroll {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 0.2rem;
      }

      .activity-cell {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 2px;
        background: var(--heat-0);
      }

      .activity-cell.level-1 { background: var(--heat-1); }
      .activity-cell.level-2 { background: var(--heat-2); }
      .activity-cell.level-3 { background: var(--heat-3); }
      .activity-cell.level-4 { background: var(--heat-4); }

      .activity-months {
        display: grid;
        grid-template-columns: repeat(53, minmax(10px, 1fr));
        gap: 3px;
        min-width: 686px;
        width: 100%;
        color: var(--muted);
        font-size: 0.8rem;
        margin-bottom: 0.55rem;
      }

      .activity-months span {
        white-space: nowrap;
      }

      .summary-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
      }

      .summary-card strong,
      .post-card h3,
      .panel h3 {
        display: block;
        margin-bottom: 0.2rem;
        color: var(--ink);
        font-size: 1rem;
      }

      .summary-card p {
        margin-top: 0.35rem;
      }

      .metric-value {
        display: block;
        font-size: 1.4rem;
        color: var(--ink);
        margin-bottom: 0.25rem;
      }

      .three-col-list {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.2rem;
      }

      .timeline-stack {
        position: relative;
        display: grid;
        gap: 1rem;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
      }

      .timeline-stack::before {
        content: "";
        position: absolute;
        left: 0.45rem;
        top: 0.35rem;
        bottom: 0.35rem;
        width: 2px;
        background: linear-gradient(180deg, var(--accent-soft), rgba(255, 138, 52, 0.16));
      }

      .timeline-card {
        position: relative;
        padding: 1.2rem 1.2rem 1.2rem 1.4rem;
        background:
          linear-gradient(135deg, rgba(255, 138, 52, 0.08), transparent 26%),
          var(--panel);
      }

      .timeline-card::before {
        content: "";
        position: absolute;
        left: -1.34rem;
        top: 1.2rem;
        width: 0.85rem;
        height: 0.85rem;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 6px rgba(255, 138, 52, 0.12);
      }

      .timeline-period {
        color: var(--accent-soft);
        font-size: 0.8rem;
        margin-bottom: 0.55rem;
        letter-spacing: 0.04em;
      }

      .timeline-detail {
        margin-top: 0.5rem;
      }

      .timeline-points {
        margin: 0.75rem 0 0;
        padding-left: 1.05rem;
        display: grid;
        gap: 0.45rem;
      }

      .timeline-points li {
        color: var(--muted);
      }

      .entry-title {
        color: var(--ink);
        font-size: 1.05rem;
        margin-bottom: 0.35rem;
      }

      .entry-subtitle {
        color: var(--muted);
        margin-bottom: 0.6rem;
        font-size: 0.92rem;
      }

      .post-card a,
      .entry-link {
        text-decoration: none;
      }

      .post-card .meta,
      .repo-card .meta {
        color: var(--muted);
        margin-bottom: 0.25rem;
      }

      .legacy-note {
        color: var(--accent-soft);
        margin-top: 0.2rem;
      }

      .cover-image {
        width: 100%;
        height: auto;
        object-fit: cover;
        background:
          radial-gradient(circle at top right, rgba(255, 138, 52, 0.12), transparent 34%),
          var(--panel-strong);
        border: 1px solid var(--line-soft);
        margin: 0.85rem 0 1rem;
        display: block;
      }

      .contact-card {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        width: 100%;
      }

      .contact-card .contact-item {
        min-width: 0;
        flex: 1 1 12rem;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        justify-content: center;
      }

      .contact-card strong {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--ink);
        margin: 0;
        font-size: 0.95rem;
      }

      .contact-card strong::before {
        content: "";
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 0.2rem;
        background: linear-gradient(135deg, var(--accent), var(--accent-soft));
        display: inline-block;
      }

      .contact-card p {
        margin: 0;
      }

      .tool-group-head {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 0.2rem;
      }

      .tool-icon {
        width: 1.8rem;
        height: 1.8rem;
        border-radius: 0.45rem;
        border: 1px solid var(--line-soft);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-soft);
        font-size: 0.78rem;
        background: rgba(255, 138, 52, 0.08);
        flex: 0 0 auto;
      }

      footer {
        margin-top: 2.5rem;
        color: var(--muted);
        font-size: 0.92rem;
        text-align: center;
      }

      .back-to-top {
        position: fixed;
        right: 1.25rem;
        bottom: 1.25rem;
        width: 2.75rem;
        height: 2.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border-color: var(--line);
        background:
          linear-gradient(135deg, rgba(255, 138, 52, 0.2), transparent 60%),
          var(--panel-strong);
        color: var(--ink);
        box-shadow: 0 0 0 4px rgba(255, 138, 52, 0.1);
        opacity: 0;
        pointer-events: none;
        transform: translateY(0.6rem);
        transition:
          opacity 160ms ease,
          transform 160ms ease,
          border-color 160ms ease;
        z-index: 30;
      }

      .back-to-top.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .back-to-top:hover,
      .back-to-top:focus-visible {
        border-color: var(--accent);
        outline: none;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
      }

      label {
        display: grid;
        gap: 0.4rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      input,
      textarea,
      select,
      button {
        font: inherit;
      }

      input,
      textarea,
      select {
        width: 100%;
        background: var(--field-bg);
        color: var(--ink);
        border: 1px solid var(--line-soft);
        padding: 0.7rem 0.8rem;
      }

      input::placeholder,
      textarea::placeholder {
        color: var(--muted);
      }

      textarea {
        min-height: 10rem;
        resize: vertical;
      }

      input:focus,
      textarea:focus,
      select:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 0.18rem var(--field-focus);
      }

      button {
        background: transparent;
        color: var(--ink);
        border: 1px solid var(--line);
        padding: 0.7rem 1rem;
        cursor: pointer;
      }

      button[aria-busy="true"] {
        cursor: wait;
        opacity: 0.72;
      }

      button[aria-busy="true"]::after {
        content: "";
        width: 0.75rem;
        height: 0.75rem;
        margin-left: 0.45rem;
        border: 2px solid currentColor;
        border-top-color: transparent;
        border-radius: 999px;
        display: inline-block;
        animation: spin 0.8s linear infinite;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .danger-button {
        border-color: rgba(255, 138, 52, 0.45);
        color: var(--accent-soft);
      }

      .helper {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .status-line {
        color: var(--accent-cool);
      }

      .post-content {
        font-size: 1rem;
        line-height: 1.6;
      }

      .post-content h2,
      .post-content h3 {
        margin-top: 1.8rem;
        margin-bottom: 0.6rem;
      }

      .post-content p,
      .post-content li {
        color: var(--ink);
        line-height: 1.6;
        margin-bottom: 0.8rem;
      }

      .post-content pre,
      .post-content blockquote {
        border: 1px solid var(--line-soft);
        padding: 0.9rem;
        overflow-x: auto;
      }

      .post-content pre {
        background: rgba(0, 0, 0, 0.28);
      }

      :root[data-theme="light"] .post-content pre {
        background: rgba(17, 17, 17, 0.05);
      }

      .post-content code {
        font-family: "IBM Plex Mono", "Courier New", monospace;
        font-size: 0.94em;
      }

      .post-content :not(pre) > code {
        background: rgba(255, 138, 52, 0.12);
        border: 1px solid var(--line-soft);
        padding: 0.12rem 0.35rem;
      }

      .post-content pre code {
        display: block;
        white-space: pre;
        min-width: max-content;
        color: var(--ink);
      }

      .post-content img,
      .post-content figure img {
        display: block;
        max-width: 100% !important;
        height: auto !important;
        margin: 1rem auto;
        border: 1px solid var(--line-soft);
      }

      .post-content figure,
      .post-content .wp-block-image {
        max-width: 100%;
        margin: 1rem 0;
        overflow: hidden;
      }

      .post-content table {
        display: block;
        width: 100%;
        overflow-x: auto;
        border-collapse: collapse;
        margin: 1rem 0;
      }

      .post-content th,
      .post-content td {
        border: 1px solid var(--line-soft);
        padding: 0.55rem 0.7rem;
        text-align: left;
      }

      .post-content ul,
      .post-content ol {
        padding-left: 1.2rem;
      }

      @media (max-width: 1100px) {
        .contact-card,
        .grid.three,
        .three-col-list,
        .summary-strip,
        .form-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 820px) {
        .grid.two {
          grid-template-columns: 1fr;
        }

        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .activity-months {
          min-width: 686px;
        }

        .back-to-top {
          right: 0.9rem;
          bottom: 0.9rem;
          width: 2.45rem;
          height: 2.45rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <img class="brand-mark" src="/logo.png" alt="isuvo logo" />
          <span class="brand-copy">
            <strong>{profile.shortName}</strong>
            <span>{profile.subtitle}</span>
          </span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href="/" {...navProps('/')}>Home</a>
          <a href="/blog" {...navProps('/blog')}>Blog</a>
          <a href="/write" {...navProps('/write')}>Write</a>
          <a href={profile.links.resume} target="_blank" rel="noreferrer">Resume</a>
          <button type="button" id="theme-toggle" class="theme-toggle">Theme</button>
        </nav>
      </header>
      <slot />
      <footer>
        &copy; {year} isuvo. For professional inquiries, contact <a href="mailto:admin@ixuvo.com">admin@ixuvo.com</a>.
      </footer>
    </div>
    <button type="button" id="back-to-top" class="back-to-top" aria-label="Back to top">↑</button>
    <script is:inline>
      const storageKey = 'isuvo_theme';
      const root = document.documentElement;
      const toggle = document.getElementById('theme-toggle');
      const backToTop = document.getElementById('back-to-top');

      function applyTheme(theme) {
        root.setAttribute('data-theme', theme);
        if (toggle) {
          toggle.textContent = theme === 'light' ? 'Dark Mode' : 'Light Mode';
          toggle.dataset.theme = theme;
          toggle.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
        }
      }

      const storedTheme = localStorage.getItem(storageKey);
      applyTheme(storedTheme || 'dark');

      toggle?.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        localStorage.setItem(storageKey, next);
        applyTheme(next);
      });

      function updateBackToTop() {
        backToTop?.classList.toggle('is-visible', window.scrollY > 420);
      }

      window.addEventListener('scroll', updateBackToTop, { passive: true });
      updateBackToTop();

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
