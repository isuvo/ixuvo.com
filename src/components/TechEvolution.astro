---
const eras = [
  {
    era: '2010+',
    year: 'Foundations',
    role: 'Early Career Dev',
    company: 'Enterprise & Telecom Systems',
    description: 'Built the logic for real-time inventory and billing. Focused on high-availability backend services and automated data pipelines.',
    skills: [
      ['Programming & DSA', 'dev', '148, 163, 184'],
      ['Backend Engineering', 'api', '59, 130, 246'],
      ['Data Integrity', 'db', '139, 92, 246'],
      ['Automated ETL', 'db', '139, 92, 246'],
      ['Logic Optimization', 'dev', '148, 163, 184'],
    ],
  },
  {
    era: '2013+',
    year: 'Service Orientation',
    role: 'System Developer',
    company: 'FCDO, UK Government',
    description: 'Architected resilient RESTful services and public transparency platforms. Focused on CQRS, DDD, and enterprise-grade APIs.',
    skills: [
      ['System Design', 'sd', '168, 85, 247'],
      ['Development', 'dev', '148, 163, 184'],
      ['API Design', 'api', '59, 130, 246'],
      ['CQRS / DDD', 'arc', '6, 182, 212'],
      ['Reliable Services', 'sd', '168, 85, 247'],
    ],
  },
  {
    era: '2019+',
    year: 'Platform Scale',
    role: 'Senior System Developer',
    company: 'FCDO, UK Government',
    description: 'Led the migration to cloud-native microservices. Reduced latency by 80% using containerization and DevSecOps automation.',
    skills: [
      ['Deployment & Migration', 'ops', '245, 158, 11'],
      ['Docker / Kubernetes', 'ops', '245, 158, 11'],
      ['Platform Engineering', 'ops', '245, 158, 11'],
      ['Distributed Systems', 'sd', '168, 85, 247'],
    ],
  },
  {
    era: '2024+',
    year: 'Advanced Research',
    role: 'AI Researcher & Intern',
    company: "Bishop's / Healthsign",
    description: 'Developed graph-based vulnerability detection (GNNs) and HIPAA-compliant AI defense for IoT medical platforms.',
    skills: [
      ['RAG / LLM Orchestration', 'ai', '16, 185, 129'],
      ['GNNs / Transformers', 'ai', '16, 185, 129'],
      ['Causal AI', 'ai', '16, 185, 129'],
      ['Cybersecurity AI', 'ai', '16, 185, 129'],
      ['Python Ecosystem', 'dev', '148, 163, 184'],
    ],
  },
  {
    era: 'Current',
    year: 'Intelligent Systems',
    role: 'Engineering Lead',
    company: 'Kage Technologies Inc.',
    description: 'Directing AI-driven SaaS architecture on GCP. Orchestrating agentic workflows and LLMOps using Python and Node.js.',
    skills: [
      ['Business Integration', 'arc', '6, 182, 212'],
      ['Management', 'pm', '244, 63, 94'],
      ['Agentic AI / RAG', 'ai', '16, 185, 129'],
      ['GCP Architecture', 'ops', '245, 158, 11'],
      ['AI System Design', 'sd', '168, 85, 247'],
    ],
  },
];

const activeIndex = eras.length - 1;
const activeEra = eras[activeIndex];
const foundationSkills = [...new Set(eras.slice(0, activeIndex).flatMap((era) => era.skills.map((skill) => skill[0])))];
const totals = eras.map((_, index) => eras.slice(0, index + 1).reduce((sum, era) => sum + era.skills.length, 0));
const maxTotal = totals.at(-1) ?? 1;
---

<div class="evolution-widget" data-evolution-widget>
  <div class="evolution-header">
    <div class="evolution-title">
      <h3>Expertise Evolution</h3>
      <p>Resilient platforms, scalable systems, and applied AI.</p>
    </div>
    <div class="era-nav" role="tablist" aria-label="Technology eras">
      {eras.map((era, index) => (
        <button
          class:list={['era-button', { 'is-active': index === activeIndex }]}
          type="button"
          role="tab"
          id={`era-tab-${index}`}
          aria-selected={index === activeIndex ? 'true' : 'false'}
          aria-controls="era-details"
          tabindex={index === activeIndex ? 0 : -1}
          data-era-index={index}
        >
          {era.era}
        </button>
      ))}
    </div>
  </div>

  <div class="evolution-grid">
    <div class="skill-panel">
      <div class="skill-group">
        <div class="group-label">Capabilities Added</div>
        <div class="pill-cloud" data-new-skills>
          {activeEra.skills.map(([name, , rgb]) => (
            <span class="skill-pill is-highlighted" style={`--skill-color: rgb(${rgb}); --skill-rgb: ${rgb}`}>{name}</span>
          ))}
        </div>
      </div>

      <div class="skill-group">
        <div class="group-label">Foundation Skills</div>
        <div class="pill-cloud" data-foundation-skills>
          {foundationSkills.map((name) => <span class="skill-pill">{name}</span>)}
        </div>
      </div>
    </div>

    <div class="evolution-sidebar">
      <div
        class="context-card"
        id="era-details"
        role="tabpanel"
        aria-live="polite"
        aria-labelledby={`era-tab-${activeIndex}`}
      >
        <div class="context-kicker" data-era-year>{activeEra.year}</div>
        <div class="role-title" data-era-role>{activeEra.role}</div>
        <div class="role-company" data-era-company>{activeEra.company}</div>
        <p class="role-description" data-era-description>{activeEra.description}</p>
      </div>

      <div class="context-card growth-card">
        <div class="context-kicker">Stack Growth</div>
        <div class="depth-chart" data-depth-chart aria-label="Cumulative skill growth by era">
          {totals.map((total, index) => (
            <span
              class:list={['depth-bar', { 'is-active': index === activeIndex }]}
              style={`height: ${(total / maxTotal) * 100}%`}
              title={`${eras[index].era}: ${total} cumulative skills`}
            ></span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="evolution-legend" aria-label="Skill category legend">
    <span><i style="--legend-color: #10b981"></i>AI/ML</span>
    <span><i style="--legend-color: #3b82f6"></i>Backend</span>
    <span><i style="--legend-color: #f59e0b"></i>Cloud</span>
    <span><i style="--legend-color: #06b6d4"></i>Architecture</span>
    <span><i style="--legend-color: #a855f7"></i>System Design</span>
    <span><i style="--legend-color: #94a3b8"></i>Development</span>
    <span><i style="--legend-color: #f43f5e"></i>Leadership</span>
  </div>

  <script is:inline type="application/json" data-evolution-data set:html={JSON.stringify(eras)}></script>
</div>

<script is:inline>
  function initializeEvolutionWidgets() {
    document.querySelectorAll('[data-evolution-widget]').forEach((widget) => {
      if (!(widget instanceof HTMLElement) || widget.dataset.initialized === 'true') return;

      const dataElement = widget.querySelector('[data-evolution-data]');
      const buttons = [...widget.querySelectorAll('[data-era-index]')];
      const newSkills = widget.querySelector('[data-new-skills]');
      const foundationSkills = widget.querySelector('[data-foundation-skills]');
      const detailPanel = widget.querySelector('#era-details');
      const year = widget.querySelector('[data-era-year]');
      const role = widget.querySelector('[data-era-role]');
      const company = widget.querySelector('[data-era-company]');
      const description = widget.querySelector('[data-era-description]');
      const chart = widget.querySelector('[data-depth-chart]');

      if (!dataElement?.textContent || !newSkills || !foundationSkills || !detailPanel || !chart) return;

      let eras;
      try {
        eras = JSON.parse(dataElement.textContent);
      } catch {
        return;
      }

      const scopeAttribute = [...widget.attributes]
        .map((attribute) => attribute.name)
        .find((name) => name.startsWith('data-astro-cid-'));

      const applyScope = (element) => {
        if (scopeAttribute) element.setAttribute(scopeAttribute, '');
        return element;
      };

      const makePill = (name, rgb) => {
        const pill = applyScope(document.createElement('span'));
        pill.className = rgb ? 'skill-pill is-highlighted' : 'skill-pill';
        pill.textContent = name;
        if (rgb) {
          pill.style.setProperty('--skill-color', `rgb(${rgb})`);
          pill.style.setProperty('--skill-rgb', rgb);
        }
        return pill;
      };

      const selectEra = (activeIndex, moveFocus = false) => {
        const activeEra = eras[activeIndex];
        if (!activeEra) return;

        buttons.forEach((button, index) => {
          const isActive = index === activeIndex;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-selected', String(isActive));
          button.setAttribute('tabindex', isActive ? '0' : '-1');
        });

        if (moveFocus) buttons[activeIndex]?.focus();
        detailPanel.setAttribute('aria-labelledby', `era-tab-${activeIndex}`);
        if (year) year.textContent = activeEra.year;
        if (role) role.textContent = activeEra.role;
        if (company) company.textContent = activeEra.company;
        if (description) description.textContent = activeEra.description;

        newSkills.replaceChildren(...activeEra.skills.map(([name, , rgb]) => makePill(name, rgb)));
        const priorSkills = eras.slice(0, activeIndex).flatMap((era) => era.skills.map(([name]) => name));
        const uniqueSkills = [...new Set(priorSkills)];
        foundationSkills.replaceChildren(
          ...(uniqueSkills.length ? uniqueSkills.map((name) => makePill(name)) : [makePill('Foundational Era')]),
        );

        const totals = eras.map((_, index) => eras.slice(0, index + 1).reduce((sum, era) => sum + era.skills.length, 0));
        const maxTotal = totals.at(-1) || 1;
        chart.replaceChildren(...totals.map((total, index) => {
          const bar = applyScope(document.createElement('span'));
          bar.className = index === activeIndex ? 'depth-bar is-active' : 'depth-bar';
          bar.style.height = `${(total / maxTotal) * 100}%`;
          bar.title = `${eras[index].era}: ${total} cumulative skills`;
          return bar;
        }));
      };

      buttons.forEach((button, index) => {
        button.addEventListener('click', () => selectEra(index));
        button.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          let nextIndex = index;
          if (event.key === 'ArrowLeft') nextIndex = (index - 1 + buttons.length) % buttons.length;
          if (event.key === 'ArrowRight') nextIndex = (index + 1) % buttons.length;
          if (event.key === 'Home') nextIndex = 0;
          if (event.key === 'End') nextIndex = buttons.length - 1;
          selectEra(nextIndex, true);
        });
      });

      widget.dataset.initialized = 'true';
    });
  }

  initializeEvolutionWidgets();
  document.addEventListener('astro:page-load', initializeEvolutionWidgets);
</script>

<style>
  .evolution-widget {
    --widget-surface: color-mix(in srgb, var(--panel-strong) 88%, transparent);
    --widget-inset: color-mix(in srgb, var(--panel-strong) 72%, var(--bg));
    width: 100%;
    font-family: inherit;
    font-size: 1rem;
    padding: clamp(1.1rem, 3vw, 2rem);
    overflow: hidden;
    color: var(--ink);
    background:
      radial-gradient(circle at 88% 0%, color-mix(in srgb, var(--accent) 11%, transparent), transparent 30%),
      var(--widget-surface);
    border: 1px solid var(--line-soft);
    border-radius: 1rem;
    box-shadow: var(--shadow);
  }

  .evolution-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .evolution-title h3 {
    margin: 0 0 0.3rem;
    font-family: inherit;
    font-size: 1.08rem;
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    letter-spacing: 0;
  }

  .evolution-title p {
    font-size: 1rem;
    font-weight: var(--weight-regular);
  }

  .era-nav {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.35rem;
    width: min(100%, 28rem);
    padding: 0.3rem;
    overflow: visible;
    background: var(--widget-inset);
    border: 1px solid var(--line-soft);
    border-radius: 0.75rem;
    scrollbar-width: thin;
  }

  .era-button {
    min-width: 0;
    min-height: 2.35rem;
    padding: 0.5rem 0.6rem;
    color: var(--muted);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: var(--weight-semibold);
    line-height: 1;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.55rem;
    cursor: pointer;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .era-button:hover,
  .era-button:focus-visible {
    color: var(--ink);
    border-color: var(--line-soft);
  }

  .era-button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .era-button.is-active {
    color: var(--accent-contrast);
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0.4rem 1.25rem color-mix(in srgb, var(--accent) 28%, transparent);
  }

  .evolution-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 18rem);
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .skill-panel,
  .evolution-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .group-label {
    margin-bottom: 0.75rem;
    color: var(--muted);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    letter-spacing: 0;
  }

  .context-kicker {
    margin-bottom: 0.75rem;
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pill-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.7rem;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: var(--weight-medium);
    line-height: 1.25;
    background: var(--button-surface);
    border: 1px solid var(--line-soft);
    border-radius: 0.5rem;
  }

  .skill-pill.is-highlighted {
    color: var(--skill-color);
    background: rgba(var(--skill-rgb), 0.1);
    border-color: color-mix(in srgb, var(--skill-color) 78%, var(--line-soft));
  }

  .context-card {
    padding: 1.15rem;
    background: var(--widget-inset);
    border: 1px solid var(--line-soft);
    border-radius: 0.8rem;
  }

  .context-kicker {
    margin-bottom: 0.5rem;
  }

  .role-title {
    margin-bottom: 0.25rem;
    color: var(--accent-soft);
    font-size: 1.05rem;
    font-weight: var(--weight-semibold);
  }

  .role-company {
    margin-bottom: 0.75rem;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: var(--weight-regular);
  }

  .role-description {
    color: var(--ink);
    font-size: 1rem;
    font-weight: var(--weight-regular);
    line-height: 1.65;
    opacity: 0.88;
  }

  .growth-card {
    padding-bottom: 0.9rem;
  }

  .depth-chart {
    display: flex;
    align-items: flex-end;
    gap: 0.4rem;
    height: 5rem;
    margin-top: 0.75rem;
  }

  .depth-bar {
    flex: 1;
    min-width: 0.55rem;
    background: var(--line-soft);
    border-radius: 0.25rem 0.25rem 0.1rem 0.1rem;
    transition: height 320ms ease, background-color 180ms ease, box-shadow 180ms ease;
  }

  .depth-bar.is-active {
    background: linear-gradient(180deg, var(--accent-soft), var(--accent));
    box-shadow: 0 0 1rem color-mix(in srgb, var(--accent) 24%, transparent);
  }

  .evolution-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: var(--weight-regular);
    border-top: 1px solid var(--line-soft);
  }

  .evolution-legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .evolution-legend i {
    width: 0.55rem;
    height: 0.55rem;
    flex: 0 0 auto;
    background: var(--legend-color);
    border-radius: 50%;
  }

  @media (max-width: 820px) {
    .evolution-header {
      flex-direction: column;
      gap: 1rem;
    }

    .era-nav {
      width: 100%;
    }

    .evolution-grid {
      grid-template-columns: 1fr;
    }

    .evolution-sidebar {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(10rem, 1fr);
    }
  }

  @media (max-width: 520px) {
    .evolution-widget {
      padding: 1rem;
      border-radius: 0.8rem;
    }

    .evolution-header {
      margin-bottom: 1.35rem;
    }

    .era-button {
      padding-inline: 0.3rem;
      font-size: 0.8rem;
    }

    .evolution-sidebar {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .era-button,
    .depth-bar {
      transition: none;
    }
  }
</style>
