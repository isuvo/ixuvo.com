---
import BaseLayout from '../layouts/BaseLayout.astro';

const pocketbaseUrl = String(import.meta.env.PB_URL || '').trim().replace(/\/$/, '');
const writerCookieName = 'ixuvo_writer_session';
const adminUiUrl = String(import.meta.env.PUBLIC_PB_URL || '').trim().replace(/\/$/, '') + '/_/';

if (!pocketbaseUrl) {
  throw new Error('PB_URL environment variable is required.');
}

let writerRecord = null;
const writerToken = Astro.cookies.get(writerCookieName)?.value;
if (writerToken) {
  try {
    const response = await fetch(`${pocketbaseUrl}/api/collections/blog_authors/auth-refresh`, {
      method: 'POST',
      headers: { Authorization: `Bearer ${writerToken}` },
    });
    const data = await response.json();
    if (response.ok && data.record?.verified === true) {
      writerRecord = data.record;
    } else {
      Astro.cookies.delete(writerCookieName, { path: '/' });
    }
  } catch {
    Astro.cookies.delete(writerCookieName, { path: '/' });
  }
}

const writerAuthenticated = Boolean(writerRecord);
---

<BaseLayout
  title="Blog Writer | isuvo"
  description="Private authoring workspace for managing isuvo blog posts."
  canonical="/write"
  noindex={true}
>
  <section class="hero">
    <h1>Write</h1>
    <p class="lead-copy">
      Manage blog posts, drafts, publishing, and deletion in one place (PocketBase).
    </p>
  </section>

  <section class="section">
    <div class="grid two">
      <article class="panel">
        <h2 style="margin-bottom:0.8rem;">Author Login</h2>
        <form id="login-form" class="grid" style="gap:0.8rem;">
          <label>
            Email
            <input type="email" name="identity" autocomplete="username" required />
          </label>
          <label>
            Password
            <input type="password" name="password" autocomplete="current-password" required />
          </label>
          <div class="pill-row">
            <button type="submit">Log In</button>
            <button type="button" id="logout-btn">Log Out</button>
          </div>
        </form>
        <p class="helper" style="margin-top:0.8rem;">Public signup is disabled.</p>
        {import.meta.env.PUBLIC_PB_URL ? (
          <p class="helper" style="margin-top:0.4rem;">
            PocketBase admin UI: <a href={adminUiUrl} target="_blank" rel="noreferrer">{adminUiUrl}</a>
          </p>
        ) : null}
        <p id="auth-status" class="status-line" style="margin-top:0.8rem;"></p>
      </article>

      <article class="panel">
        <h2 style="margin-bottom:0.8rem;">Existing Posts</h2>
        <label style="margin-bottom:0.8rem;">
          Search Existing Posts
          <input id="post-search" type="search" placeholder="Search title, slug, status, or tags..." />
        </label>
        <div id="post-list" class="grid post-list" style="gap:0.8rem;">
          <p class="helper">Log in to load your posts.</p>
        </div>
        <div class="pill-row" style="margin-top:0.8rem;">
          <button type="button" id="load-more-posts">Load More</button>
        </div>
      </article>
    </div>
  </section>

  {writerAuthenticated ? (
  <section id="post-editor-section" class="section">
    <article class="panel">
      <h2 style="margin-bottom:0.8rem;">Post Editor</h2>
      <form id="post-form" class="grid" style="gap:0.9rem;">
        <input type="hidden" name="post_id" />
        <div class="editor-import-tools">
          <label>
            Import Markdown File
            <input id="markdown-import" type="file" accept=".md,.markdown,text/markdown,text/plain" />
            <span class="helper">Import a Markdown draft before filling or reviewing the post fields.</span>
            <a class="template-link" href="/blog-post-template.md" download>Download Markdown Template</a>
          </label>
        </div>
        <div class="form-grid">
          <label>
            Title
            <input type="text" name="title" required />
          </label>
          <label>
            Slug
            <input type="text" name="slug" required />
          </label>
        </div>
        <label>
          Summary
          <textarea name="summary" style="min-height:6rem;" required></textarea>
          <span id="summary-counter" class="field-counter" aria-live="polite">0 words · 0 / 1,200 characters</span>
        </label>
        <label>
          <span class="editor-label-row">
            <span>Body Markdown</span>
            <button type="button" id="insert-image-marker-btn" class="inline-tool-button">Place Image Marker</button>
          </span>
          <textarea name="body_markdown" maxlength="20000" required></textarea>
          <span class="helper">Place the cursor between paragraphs, then place the marker before uploading.</span>
          <span id="body-counter" class="field-counter" aria-live="polite">0 words · 0 / 20,000 characters</span>
        </label>
        <div class="media-tools">
          <div class="media-tool">
            <span class="media-tool-title">Embedded Body Image</span>
            <input id="embedded-images" type="file" accept="image/*" multiple />
            <button type="button" id="upload-embedded-images-btn">Upload & Insert at Marker</button>
            <span class="helper">Save or load the post first. Place the image marker in the body before uploading.</span>
            <span id="embedded-upload-status" class="upload-status" aria-live="polite"></span>
          </div>
          <label class="media-tool">
            Cover Image
            <input type="file" name="cover_image" accept="image/*" />
            <span class="helper">Optional. JPG, PNG, WebP, or GIF up to 5 MB.</span>
          </label>
        </div>
        <div class="form-grid">
          <label>
            Status
            <select name="status">
              <option value="draft">Draft</option>
              <option value="review">Review</option>
              <option value="approved">Approved</option>
              <option value="published">Published</option>
              <option value="archived">Archived</option>
            </select>
          </label>
          <label>
            Published At
            <input type="datetime-local" name="published_at" />
          </label>
        </div>
        <fieldset class="tag-selector">
          <legend>Tags</legend>
          <div class="tag-quick-actions" aria-label="Quick add tags">
            <button type="button" class="tag-quick-button" data-tag-value="ai" data-tag-alias="ai systems">AI Systems</button>
            <button type="button" class="tag-quick-button" data-tag-value="automation">Automation</button>
            <button type="button" class="tag-quick-button" data-tag-value="cloud">Cloud</button>
            <button type="button" class="tag-quick-button" data-tag-value="devsecops">DevSecOps</button>
            <button type="button" class="tag-quick-button" data-tag-value="security">Security</button>
            <button type="button" class="tag-quick-button" data-tag-value="system-design" data-tag-alias="system design">System Design</button>
            <button type="button" class="tag-quick-button" data-tag-value="general">General</button>
            <button type="button" class="tag-quick-button" data-tag-value="management">Management</button>
            <button type="button" class="tag-quick-button" data-tag-value="ops">Ops</button>
            <button type="button" class="tag-quick-button" data-tag-value="legacy" data-tag-alias="legacy archive">Legacy Archive</button>
          </div>
          <textarea name="tags" class="tag-input" placeholder="AI Security, Cloud, DevSecOps" required>general</textarea>
          <span class="helper">Use the buttons or enter custom tags separated by commas or new lines.</span>
        </fieldset>
        <label>
          Source URLs
          <textarea name="source_urls" style="min-height:6rem;" placeholder="one URL per line"></textarea>
        </label>
        <div class="form-grid">
          <label>
            LinkedIn Text
            <textarea name="linkedin_text" style="min-height:8rem;"></textarea>
          </label>
          <label>
            X Text
            <textarea name="x_text" style="min-height:8rem;"></textarea>
          </label>
        </div>
        <div class="pill-row">
          <button type="submit" id="save-post-btn">Save Post</button>
          <button type="button" id="new-post-btn">New Post</button>
          <button type="button" id="delete-post-btn" class="danger-button">Delete Post</button>
        </div>
        <p id="editor-validation-error" class="form-error" role="alert" hidden></p>
        <p id="editor-status" class="status-line"></p>
      </form>
    </article>
  </section>
  ) : null}

  <script define:vars={{ writerAuthenticated, writerRecord }} is:inline>
    const authKey = 'isuvo_pb_auth';
    const sessionMs = 4 * 60 * 60 * 1000;
    const pageSize = 12;
    const initialWriterAuthenticated = writerAuthenticated === true;
    const initialWriterRecord = writerRecord;
    const loginForm = document.getElementById('login-form');
    const postForm = document.getElementById('post-form');
    const editorAvailable = Boolean(postForm);
    const authStatus = document.getElementById('auth-status');
    const editorStatus = document.getElementById('editor-status');
    const validationError = document.getElementById('editor-validation-error');
    const summaryCounter = document.getElementById('summary-counter');
    const bodyCounter = document.getElementById('body-counter');
    const postList = document.getElementById('post-list');
    const postSearch = document.getElementById('post-search');
    const loadMorePostsBtn = document.getElementById('load-more-posts');
    const logoutBtn = document.getElementById('logout-btn');
    const newPostBtn = document.getElementById('new-post-btn');
    const deletePostBtn = document.getElementById('delete-post-btn');
    const savePostBtn = document.getElementById('save-post-btn');
    const markdownImport = document.getElementById('markdown-import');
    const embeddedImagesInput = document.getElementById('embedded-images');
    const uploadEmbeddedImagesBtn = document.getElementById('upload-embedded-images-btn');
    const embeddedUploadStatus = document.getElementById('embedded-upload-status');
    const insertImageMarkerBtn = document.getElementById('insert-image-marker-btn');
    const tagQuickButtons = Array.from(document.querySelectorAll('[data-tag-value]'));
    const imagePlacementMarker = '<!-- ixuvo-image-here -->';
    const allowedImageTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
    const maxCoverImageSize = 5 * 1024 * 1024;
    const maxEmbeddedImageSize = 10 * 1024 * 1024;
    const maxMarkdownImportSize = 2 * 1024 * 1024;
    let allPosts = [];
    let visiblePostLimit = pageSize;
    let sessionTimer = null;

    function resolvePocketBaseUrl() {
      return '/api/pb';
    }

    function pocketBaseEndpoint(path) {
      const base = resolvePocketBaseUrl().replace(/\/$/, '');
      const normalizedPath = path.startsWith('/') ? path : `/${path}`;
      return `${base}${normalizedPath}`;
    }

    function slugify(value) {
      return value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function getAuth() {
      if (!initialWriterAuthenticated) {
        return null;
      }

      const raw = localStorage.getItem(authKey);
      if (raw) {
        try {
          const auth = JSON.parse(raw);
          if (auth?.record && Date.now() < auth.expiresAt) {
            return { ...auth, record: initialWriterRecord || auth.record, token: '' };
          }
        } catch {
          // The server-rendered session remains authoritative.
        }
      }

      return {
        record: initialWriterRecord,
        expiresAt: Date.now() + sessionMs,
        token: '',
      };
    }

    function setAuth(data) {
      localStorage.setItem(authKey, JSON.stringify({
        ...data,
        expiresAt: Date.now() + sessionMs,
      }));
      scheduleSessionExpiry();
    }

    function clearAuth() {
      localStorage.removeItem(authKey);
      if (sessionTimer) {
        clearTimeout(sessionTimer);
        sessionTimer = null;
      }
    }

    function hideEditor() {
      document.getElementById('post-editor-section')?.remove();
    }

    function scheduleSessionExpiry() {
      const auth = getAuth();
      if (!auth) {
        return;
      }

      if (sessionTimer) {
        clearTimeout(sessionTimer);
      }

      sessionTimer = window.setTimeout(() => {
        clearAuth();
        authStatus.textContent = 'Session expired. Please log in again.';
        postList.innerHTML = '<p class="helper">Session expired. Log in to manage posts.</p>';
        loadMorePostsBtn.style.display = 'none';
        hideEditor();
        fetch('/api/writer-auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'logout' }),
        }).finally(() => window.location.reload());
      }, Math.max(0, auth.expiresAt - Date.now()));
    }

    function formatSession(auth) {
      const expires = new Date(auth.expiresAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      return `Logged in as ${auth.record.email}. Session expires at ${expires}.`;
    }

    function parseList(value) {
      return value
        .split(/\n|,/)
        .map((item) => item.trim())
        .filter(Boolean);
    }

    function uniqueList(items) {
      return [...new Set(items.map((item) => String(item || '').trim()).filter(Boolean))];
    }

    function selectedTags() {
      const seen = new Set();
      return parseList(postForm.tags.value).filter((tag) => {
        const key = tag.toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    function setSelectedTags(tags) {
      const selected = uniqueList(Array.isArray(tags) ? tags : []);
      postForm.tags.value = (selected.length ? selected : ['general']).join(', ');
      syncTagQuickButtons();
    }

    function syncTagQuickButtons() {
      const selected = new Set(selectedTags().map((tag) => tag.toLowerCase()));
      tagQuickButtons.forEach((button) => {
        const value = button.dataset.tagValue || '';
        const alias = button.dataset.tagAlias || '';
        const active = selected.has(value) || (alias && selected.has(alias));
        button.classList.toggle('is-selected', Boolean(active));
        button.setAttribute('aria-pressed', String(Boolean(active)));
      });
    }

    function setBusy(isBusy, message = '', controls = []) {
      document.body.classList.toggle('is-busy', isBusy);
      controls.filter(Boolean).forEach((control) => {
        control.disabled = isBusy;
        control.setAttribute('aria-busy', String(isBusy));
      });

      if (message && editorStatus) {
        editorStatus.textContent = message;
      }
    }

    function showValidationErrors(errors) {
      const message = errors.join(' ');
      if (validationError) {
        validationError.textContent = message;
        validationError.hidden = !message;
      }
      if (editorStatus) {
        editorStatus.textContent = message ? `Fix before saving: ${message}` : '';
      }
    }

    function clearValidationError() {
      if (validationError) {
        validationError.textContent = '';
        validationError.hidden = true;
      }
    }

    const requiredFieldMessages = {
      title: 'Title is required.',
      slug: 'Slug is required.',
      summary: 'Summary is required.',
      body_markdown: 'Body Markdown is required.',
      tags: 'Choose a tag before saving.',
    };

    function handleInvalidField(event) {
      const field = event.target;
      const message = requiredFieldMessages[field?.name];
      if (!message) {
        return;
      }

      field.setCustomValidity(message);
      field.setAttribute('aria-invalid', 'true');
      showValidationErrors([message]);
    }

    function handleFieldInput(event) {
      const field = event.target;
      if (requiredFieldMessages[field?.name]) {
        field.setCustomValidity('');
        field.removeAttribute('aria-invalid');
      }
      clearValidationError();
    }

    function formatPocketBaseError(data, fallback) {
      const details = data?.data && typeof data.data === 'object'
        ? Object.entries(data.data)
            .map(([field, issue]) => `${field}: ${issue?.message || JSON.stringify(issue)}`)
            .join(' | ')
        : '';
      return [data?.message || fallback, details].filter(Boolean).join(' - ');
    }

    function validateUrlList(urls) {
      const invalid = urls.filter((item) => {
        try {
          const parsed = new URL(item);
          return !['http:', 'https:'].includes(parsed.protocol);
        } catch {
          return true;
        }
      });
      return invalid;
    }

    function validateCoverImage(file) {
      if (!file) {
        return '';
      }

      if (!allowedImageTypes.includes(file.type)) {
        return 'Cover image must be JPG, PNG, WebP, or GIF.';
      }

      if (file.size > maxCoverImageSize) {
        return 'Cover image must be 5 MB or smaller.';
      }

      return '';
    }

    function validateEmbeddedImages(files) {
      const images = Array.from(files || []);
      if (!images.length) {
        return 'Choose one or more images to upload.';
      }

      const invalidType = images.find((file) => !allowedImageTypes.includes(file.type));
      if (invalidType) {
        return `${invalidType.name} must be JPG, PNG, WebP, or GIF.`;
      }

      const tooLarge = images.find((file) => file.size > maxEmbeddedImageSize);
      if (tooLarge) {
        return `${tooLarge.name} must be 10 MB or smaller.`;
      }

      return '';
    }

    function validatePostForm() {
      const errors = [];
      const slug = postForm.slug.value || slugify(postForm.title.value);
      const sourceUrls = parseList(postForm.source_urls.value);
      const invalidUrls = validateUrlList(sourceUrls);
      const coverError = validateCoverImage(postForm.cover_image.files[0]);

      if (!postForm.title.value.trim()) errors.push('Title is required.');
      if (!slug) errors.push('Slug is required.');
      if (slug && !/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(slug)) errors.push('Slug can only use lowercase letters, numbers, and single hyphens.');
      if (!postForm.summary.value.trim()) errors.push('Summary is required.');
      if (postForm.summary.value.length > 1200) errors.push('Summary must be 1,200 characters or fewer.');
      if (!postForm.body_markdown.value.trim()) errors.push('Body Markdown is required.');
      if (postForm.body_markdown.value.length > 20000) errors.push('Body Markdown must be 20,000 characters or fewer.');
      if (postForm.body_markdown.value.includes(imagePlacementMarker)) errors.push('Finish placing the body image or remove the image marker before saving.');
      if (!selectedTags().length) errors.push('Choose at least one tag.');
      if (invalidUrls.length) errors.push(`Invalid source URL: ${invalidUrls[0]}`);
      if (coverError) errors.push(coverError);

      return errors;
    }

    function setEmbeddedUploadStatus(message, tone = '') {
      embeddedUploadStatus.textContent = message;
      embeddedUploadStatus.classList.remove('is-success', 'is-error');
      if (tone) {
        embeddedUploadStatus.classList.add(`is-${tone}`);
      }
    }

    function countWords(value) {
      const normalized = String(value || '').trim();
      return normalized ? normalized.split(/\s+/).length : 0;
    }

    function updateEditorCounters() {
      const summaryLength = postForm.summary.value.length;
      const bodyLength = postForm.body_markdown.value.length;
      summaryCounter.textContent = `${countWords(postForm.summary.value)} words · ${summaryLength.toLocaleString()} / 1,200 characters`;
      bodyCounter.textContent = `${countWords(postForm.body_markdown.value)} words · ${bodyLength.toLocaleString()} / 20,000 characters`;
      summaryCounter.classList.toggle('is-over-limit', summaryLength > 1200);
      bodyCounter.classList.toggle('is-over-limit', bodyLength > 20000);
    }

    function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.addEventListener('load', () => {
          const result = String(reader.result || '');
          resolve(result.includes(',') ? result.split(',').pop() : result);
        });
        reader.addEventListener('error', () => reject(new Error('Could not read the selected image.')));
        reader.readAsDataURL(file);
      });
    }

    function fileToText(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.addEventListener('load', () => resolve(String(reader.result || '')));
        reader.addEventListener('error', () => reject(new Error('Could not read the Markdown file.')));
        reader.readAsText(file);
      });
    }

    function stripQuotes(value) {
      return String(value || '').trim().replace(/^['"]|['"]$/g, '');
    }

    function parseFrontmatterList(value) {
      const trimmed = stripQuotes(value);
      if (!trimmed) {
        return [];
      }

      if (trimmed.startsWith('[') && trimmed.endsWith(']')) {
        return trimmed
          .slice(1, -1)
          .split(',')
          .map(stripQuotes)
          .filter(Boolean);
      }

      return trimmed.split(',').map(stripQuotes).filter(Boolean);
    }

    function parseMarkdownFrontmatter(markdown) {
      const match = markdown.match(/^---\s*\r?\n([\s\S]*?)\r?\n---\s*(?:\r?\n|$)/);
      if (!match) {
        return { data: {}, body: markdown };
      }

      const data = {};
      const lines = match[1].split(/\r?\n/);
      let blockKey = '';
      let blockFolded = false;
      let blockLines = [];

      const flushBlock = () => {
        if (!blockKey) {
          return;
        }

        data[blockKey] = blockLines.join(blockFolded ? ' ' : '\n').trim();
        blockKey = '';
        blockFolded = false;
        blockLines = [];
      };

      lines.forEach((line) => {
        if (blockKey) {
          if (!line.trim() || /^\s+/.test(line)) {
            blockLines.push(line.replace(/^\s{2}/, '').replace(/^\t/, ''));
            return;
          }

          flushBlock();
        }

        const field = line.match(/^([A-Za-z0-9_-]+):\s*(.*)$/);
        if (!field) {
          return;
        }

        const key = field[1].toLowerCase();
        const value = field[2];
        if (value === '|' || value === '>') {
          blockKey = key;
          blockFolded = value === '>';
        } else {
          data[key] = value;
        }
      });

      flushBlock();

      return {
        data,
        body: markdown.slice(match[0].length),
      };
    }

    function plainMarkdownExcerpt(markdown) {
      return markdown
        .replace(/```[\s\S]*?```/g, ' ')
        .replace(/!\[[^\]]*]\([^)]*\)/g, ' ')
        .replace(/\[[^\]]+]\([^)]*\)/g, ' ')
        .replace(/^#+\s+/gm, '')
        .replace(/[>*_`#-]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function toDatetimeLocal(value) {
      const raw = stripQuotes(value);
      if (!raw) {
        return '';
      }

      const date = new Date(raw);
      if (Number.isNaN(date.getTime())) {
        return '';
      }

      return date.toISOString().slice(0, 16);
    }

    function insertAtCursor(textarea, value) {
      const start = textarea.selectionStart ?? textarea.value.length;
      const end = textarea.selectionEnd ?? textarea.value.length;
      const before = textarea.value.slice(0, start);
      const after = textarea.value.slice(end);
      const prefix = before && !before.endsWith('\n') ? '\n\n' : '';
      const suffix = after && !after.startsWith('\n') ? '\n\n' : '';

      textarea.value = `${before}${prefix}${value}${suffix}${after}`;
      const cursor = before.length + prefix.length + value.length;
      textarea.focus();
      textarea.setSelectionRange(cursor, cursor);
    }

    function replaceImageMarker(textarea, value) {
      const markerIndex = textarea.value.indexOf(imagePlacementMarker);
      if (markerIndex < 0) {
        return false;
      }

      const before = textarea.value.slice(0, markerIndex).trimEnd();
      const after = textarea.value.slice(markerIndex + imagePlacementMarker.length).trimStart();
      if (!before || !after) {
        return false;
      }

      const replacement = `${before}\n\n${value}\n\n${after}`;
      textarea.value = replacement;
      const cursor = before.length + 2 + value.length;
      textarea.focus();
      textarea.setSelectionRange(cursor, cursor);
      updateEditorCounters();
      return true;
    }

    function applyMarkdownImport(markdown, filename) {
      const { data, body } = parseMarkdownFrontmatter(markdown);
      const heading = body.match(/^#\s+(.+)$/m)?.[1]?.trim();
      const importedTitle = stripQuotes(data.title) || heading || filename.replace(/\.(md|markdown)$/i, '').replace(/[-_]+/g, ' ');
      const importedSummary = stripQuotes(data.summary || data.description || data.excerpt);
      const importedTags = uniqueList(parseFrontmatterList(data.tags || data.tag || data.category));
      const importedSources = uniqueList([
        ...parseList(postForm.source_urls.value),
        ...parseFrontmatterList(data.source_urls || data.sources || data.source),
      ]);

      postForm.title.value = importedTitle;
      postForm.slug.value = stripQuotes(data.slug) || slugify(importedTitle);
      postForm.summary.value = importedSummary || `${plainMarkdownExcerpt(body).slice(0, 220)}${plainMarkdownExcerpt(body).length > 220 ? '...' : ''}`;
      postForm.body_markdown.value = body.trim();
      updateEditorCounters();
      postForm.source_urls.value = importedSources.join('\n');

      setSelectedTags(importedTags);

      const importedStatus = stripQuotes(data.status).toLowerCase();
      if (['draft', 'review', 'approved', 'published', 'archived'].includes(importedStatus)) {
        postForm.status.value = importedStatus;
      }

      postForm.published_at.value = toDatetimeLocal(data.published_at || data.date || data.published) || postForm.published_at.value;
      postForm.linkedin_text.value = stripQuotes(data.linkedin_text) || postForm.linkedin_text.value;
      postForm.x_text.value = stripQuotes(data.x_text || data.twitter_text) || postForm.x_text.value;
      editorStatus.textContent = `Imported ${filename}. Review fields, then save.`;
    }

    function resetEditor() {
      if (!postForm) {
        return;
      }

      postForm.reset();
      postForm.post_id.value = '';
      updateEditorCounters();
      syncTagQuickButtons();
      clearValidationError();
      setEmbeddedUploadStatus('');
      editorStatus.textContent = '';
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function fillEditor(post) {
      postForm.post_id.value = post.id || '';
      postForm.title.value = post.title || '';
      postForm.slug.value = post.slug || '';
      postForm.summary.value = post.summary || '';
      postForm.body_markdown.value = post.body_markdown || '';
      updateEditorCounters();
      postForm.status.value = post.status || 'draft';
      setSelectedTags(post.tags);
      postForm.source_urls.value = Array.isArray(post.source_urls) ? post.source_urls.join('\n') : '';
      postForm.linkedin_text.value = post.linkedin_text || '';
      postForm.x_text.value = post.x_text || '';
      postForm.published_at.value = post.published_at ? new Date(post.published_at).toISOString().slice(0, 16) : '';
      embeddedImagesInput.value = '';
      editorStatus.textContent = `Loaded ${post.title}`;
    }

    function matchesSearch(post) {
      const query = (postSearch.value || '').trim().toLowerCase();
      if (!query) {
        return true;
      }

      return [
        post.title,
        post.slug,
        post.status,
        Array.isArray(post.tags) ? post.tags.join(' ') : '',
      ].join(' ').toLowerCase().includes(query);
    }

    function renderPosts(reset = false) {
      const auth = getAuth();
      if (!auth) {
        postList.innerHTML = '<p class="helper">Log in to load your posts.</p>';
        loadMorePostsBtn.style.display = 'none';
        return;
      }

      if (reset) {
        visiblePostLimit = pageSize;
      }

      const visiblePosts = allPosts.filter(matchesSearch);

      if (!visiblePosts.length) {
        postList.innerHTML = '<p class="helper">No matching posts found.</p>';
        loadMorePostsBtn.style.display = 'none';
        return;
      }

      postList.innerHTML = visiblePosts.slice(0, visiblePostLimit).map((post) => `
        <div class="panel">
          <strong>${escapeHtml(post.title || 'Untitled post')}</strong>
          <p>
            <span class="status-badge status-${escapeHtml(post.status || 'draft')}">${escapeHtml(post.status || 'draft')}</span>
          </p>
          <div class="pill-row" style="margin-top:0.75rem;">
            <button type="button" data-load-id="${escapeHtml(post.id)}">Load</button>
            <button type="button" class="danger-button" data-delete-id="${escapeHtml(post.id)}" data-delete-title="${escapeHtml(post.title || 'this post')}">Delete</button>
          </div>
        </div>
      `).join('');

      loadMorePostsBtn.style.display = visiblePosts.length > visiblePostLimit ? '' : 'none';

      postList.querySelectorAll('[data-load-id]').forEach((button) => {
        button.addEventListener('click', () => {
          const post = allPosts.find((item) => item.id === button.dataset.loadId);
          if (post) {
            fillEditor(post);
          }
        });
      });

      postList.querySelectorAll('[data-delete-id]').forEach((button) => {
        button.addEventListener('click', async () => {
          const postTitle = button.dataset.deleteTitle || 'this post';
          if (!window.confirm(`Delete "${postTitle}"?`)) {
            return;
          }

          try {
            setBusy(true, `Deleting ${postTitle}...`, [button, deletePostBtn, savePostBtn]);
            await deletePost(button.dataset.deleteId);
            const successMessage = `Deleted ${postTitle}`;
            editorStatus.textContent = successMessage;
            if (postForm.post_id.value === button.dataset.deleteId) {
              resetEditor();
            }
            await fetchPosts();
            editorStatus.textContent = successMessage;
          } catch (error) {
            editorStatus.textContent = error instanceof Error ? error.message : 'Delete failed.';
          } finally {
            setBusy(false, '', [button, deletePostBtn, savePostBtn]);
          }
        });
      });
    }

    async function fetchPosts() {
      const auth = getAuth();
      if (!auth) {
        postList.innerHTML = '<p class="helper">Log in to load your posts.</p>';
        return;
      }

      const url = new URL(pocketBaseEndpoint('/api/collections/posts/records'), window.location.origin);
      url.searchParams.set('sort', '-updated');
      url.searchParams.set('perPage', '300');

      setBusy(true, 'Loading posts...', [loadMorePostsBtn]);
      try {
        const response = await fetch(url);

        const data = await response.json();
        if (!response.ok) {
          throw new Error(formatPocketBaseError(data, 'Failed to load posts.'));
        }

        const items = data.items || [];
        allPosts = items;

        if (!items.length) {
          postList.innerHTML = '<p class="helper">No posts yet. Save one from the editor to create the first entry.</p>';
          loadMorePostsBtn.style.display = 'none';
          return;
        }

        renderPosts(true);
      } finally {
        setBusy(false, '', [loadMorePostsBtn]);
        if (editorStatus?.textContent === 'Loading posts...') {
          editorStatus.textContent = '';
        }
      }
    }

    async function refreshAuthState() {
      const auth = getAuth();
      if (!auth) {
        authStatus.textContent = 'Not logged in.';
        return;
      }

      authStatus.textContent = formatSession(auth);
      scheduleSessionExpiry();
      try {
        await fetchPosts();
      } catch (error) {
        postList.innerHTML = `<p class="helper">${error instanceof Error ? error.message : 'Failed to load posts.'}</p>`;
      }
    }

    async function deletePost(postId) {
      const auth = getAuth();
      if (!auth) {
        throw new Error('Please log in first.');
      }

      const response = await fetch(pocketBaseEndpoint(`/api/collections/posts/records/${postId}`), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-HTTP-Method-Override': 'DELETE',
        },
        body: JSON.stringify({ action: 'delete' }),
      });

      if (!response.ok) {
        const data = await response.json().catch(() => ({}));
        throw new Error(formatPocketBaseError(data, 'Delete failed.'));
      }
    }

    loginForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = new FormData(loginForm);
      setBusy(true, 'Logging in...', [loginForm.querySelector('button[type="submit"]')]);

      try {
        const response = await fetch('/api/writer-auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            identity: form.get('identity'),
            password: form.get('password'),
          }),
        });

        const data = await response.json();
        if (!response.ok) {
          authStatus.textContent = formatPocketBaseError(data, 'Login failed.');
          return;
        }

        setAuth({ record: data.record });
        window.location.reload();
      } catch (error) {
        authStatus.textContent = error instanceof Error ? error.message : 'Login failed.';
      } finally {
        setBusy(false, '', [loginForm.querySelector('button[type="submit"]')]);
      }
    });

    logoutBtn.addEventListener('click', async () => {
      await fetch('/api/writer-auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'logout' }),
      }).catch(() => {});
      clearAuth();
      hideEditor();
      window.location.reload();
    });

    if (editorAvailable) {
      postForm.addEventListener('invalid', handleInvalidField, true);
      postForm.addEventListener('input', handleFieldInput);
      newPostBtn.addEventListener('click', resetEditor);
      postSearch.addEventListener('input', () => renderPosts(true));
      loadMorePostsBtn.addEventListener('click', () => {
        setBusy(true, 'Loading more posts...', [loadMorePostsBtn]);
        visiblePostLimit += pageSize;
        renderPosts(false);
        window.setTimeout(() => {
          setBusy(false, '', [loadMorePostsBtn]);
          if (editorStatus?.textContent === 'Loading more posts...') {
            editorStatus.textContent = '';
          }
        }, 180);
      });

    postForm.status.addEventListener('change', () => {
      if (postForm.status.value === 'published' && !postForm.published_at.value) {
        postForm.published_at.value = new Date().toISOString().slice(0, 16);
      }
    });

    deletePostBtn.addEventListener('click', async () => {
      if (!postForm.post_id.value) {
        editorStatus.textContent = 'Load a post first if you want to delete it.';
        return;
      }

      if (!window.confirm(`Delete "${postForm.title.value || 'this post'}"?`)) {
        return;
      }

      try {
        setBusy(true, `Deleting ${postForm.title.value || 'post'}...`, [deletePostBtn, savePostBtn]);
        await deletePost(postForm.post_id.value);
        const successMessage = `Deleted ${postForm.title.value || 'post'}`;
        editorStatus.textContent = successMessage;
        resetEditor();
        await fetchPosts();
        editorStatus.textContent = successMessage;
      } catch (error) {
        editorStatus.textContent = error instanceof Error ? error.message : 'Delete failed.';
      } finally {
        setBusy(false, '', [deletePostBtn, savePostBtn]);
      }
    });

    postForm.title.addEventListener('input', () => {
      if (!postForm.post_id.value && !postForm.slug.value.trim()) {
        postForm.slug.value = slugify(postForm.title.value);
      }
    });

    postForm.summary.addEventListener('input', updateEditorCounters);
    postForm.body_markdown.addEventListener('input', updateEditorCounters);
    postForm.tags.addEventListener('input', syncTagQuickButtons);

    tagQuickButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const value = button.dataset.tagValue;
        if (!value) return;

        const tags = selectedTags();
        const selected = new Set(tags.map((tag) => tag.toLowerCase()));
        const alias = button.dataset.tagAlias || '';
        if (!selected.has(value) && !(alias && selected.has(alias))) {
          tags.push(value);
          setSelectedTags(tags);
        }
        postForm.tags.focus();
      });
    });

    postForm.cover_image.addEventListener('change', () => {
      const error = validateCoverImage(postForm.cover_image.files[0]);
      editorStatus.textContent = error || (postForm.cover_image.files[0] ? `Cover image ready: ${postForm.cover_image.files[0].name}` : '');
    });

    markdownImport.addEventListener('change', async () => {
      const file = markdownImport.files[0];
      if (!file) {
        return;
      }

      if (file.size > maxMarkdownImportSize) {
        editorStatus.textContent = 'Markdown import must be 2 MB or smaller.';
        markdownImport.value = '';
        return;
      }

      try {
        setBusy(true, `Importing ${file.name}...`, [savePostBtn, uploadEmbeddedImagesBtn]);
        applyMarkdownImport(await fileToText(file), file.name);
      } catch (error) {
        editorStatus.textContent = error instanceof Error ? error.message : 'Markdown import failed.';
      } finally {
        markdownImport.value = '';
        setBusy(false, '', [savePostBtn, uploadEmbeddedImagesBtn]);
      }
    });

    embeddedImagesInput.addEventListener('change', () => {
      const error = validateEmbeddedImages(embeddedImagesInput.files);
      if (error) {
        setEmbeddedUploadStatus(error, 'error');
        editorStatus.textContent = error;
        return;
      }

      setEmbeddedUploadStatus(`${embeddedImagesInput.files.length} image${embeddedImagesInput.files.length === 1 ? '' : 's'} selected. Place the marker, then upload.`);
      editorStatus.textContent = '';
    });

    insertImageMarkerBtn.addEventListener('click', () => {
      const body = postForm.body_markdown;
      if (body.value.includes(imagePlacementMarker)) {
        body.focus();
        setEmbeddedUploadStatus('An image marker is already placed in the body.', 'error');
        editorStatus.textContent = 'An image marker is already placed in the body.';
        return;
      }

      const cursor = body.selectionStart ?? body.value.length;
      const before = body.value.slice(0, cursor).trim();
      const after = body.value.slice(cursor).trim();
      if (!before || !after) {
        body.focus();
        setEmbeddedUploadStatus('Click between paragraphs in the body before placing the marker.', 'error');
        editorStatus.textContent = 'Click between paragraphs in the body, then place the image marker.';
        return;
      }

      insertAtCursor(body, imagePlacementMarker);
      setEmbeddedUploadStatus('Marker placed. The selected image will be inserted here.');
      editorStatus.textContent = 'Image marker placed. Choose the image file, then upload it.';
    });

    uploadEmbeddedImagesBtn.addEventListener('click', async () => {
      const auth = getAuth();
      if (!auth) {
        setEmbeddedUploadStatus('Please log in before uploading a body image.', 'error');
        editorStatus.textContent = 'Please log in first.';
        return;
      }

      const postId = postForm.post_id.value;
      if (!postId) {
        setEmbeddedUploadStatus('Save the post as a draft first, then upload the body image.', 'error');
        editorStatus.textContent = 'Save or load the post before uploading embedded images.';
        return;
      }

      const files = Array.from(embeddedImagesInput.files || []);
      const imageError = validateEmbeddedImages(files);
      if (imageError) {
        setEmbeddedUploadStatus(imageError, 'error');
        editorStatus.textContent = imageError;
        return;
      }

      const markerIndex = postForm.body_markdown.value.indexOf(imagePlacementMarker);
      if (markerIndex < 0) {
        setEmbeddedUploadStatus('Place the image marker inside the body before uploading.', 'error');
        editorStatus.textContent = 'Place an image marker inside the body before uploading.';
        return;
      }

      const markerBefore = postForm.body_markdown.value.slice(0, markerIndex).trim();
      const markerAfter = postForm.body_markdown.value.slice(markerIndex + imagePlacementMarker.length).trim();
      if (!markerBefore || !markerAfter) {
        setEmbeddedUploadStatus('Place the marker between post content, not at the beginning or end.', 'error');
        editorStatus.textContent = 'Place the image marker between the post content, not at the beginning or end.';
        return;
      }

      try {
        setBusy(true, 'Uploading embedded images...', [uploadEmbeddedImagesBtn, savePostBtn, deletePostBtn]);
        setEmbeddedUploadStatus('Uploading body image...', '');
        const previousPost = allPosts.find((post) => post.id === postId);
        const previousImages = Array.isArray(previousPost?.embedded_images) ? previousPost.embedded_images : [];
        const uploadedImages = [];

        for (const file of files) {
          uploadedImages.push({
            name: file.name,
            type: file.type,
            data: await fileToBase64(file),
          });
        }

        const response = await fetch(pocketBaseEndpoint(`/api/collections/posts/records/${postId}`), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ _embedded_images: uploadedImages }),
        });

        const data = await response.json();
        if (!response.ok) {
          const message = formatPocketBaseError(data, 'Embedded image upload failed.');
          setEmbeddedUploadStatus(message, 'error');
          editorStatus.textContent = message;
          return;
        }

        const currentImages = Array.isArray(data.embedded_images) ? data.embedded_images : [];
        const newImages = currentImages.filter((filename) => !previousImages.includes(filename)).slice(-files.length);
        if (newImages.length !== files.length) {
          const message = `Upload incomplete. PocketBase confirmed ${newImages.length} of ${files.length} image${files.length === 1 ? '' : 's'}.`;
          setEmbeddedUploadStatus(message, 'error');
          editorStatus.textContent = message;
          return;
        }

        const markdown = newImages.map((filename, index) => {
          const alt = files[index]?.name?.replace(/\.[^.]+$/, '').replace(/[-_]+/g, ' ') || 'Post image';
          return `![${alt}](/api/pb/api/files/posts/${data.id}/${encodeURIComponent(filename)})`;
        }).join('\n\n');

        if (!markdown || !replaceImageMarker(postForm.body_markdown, markdown)) {
          const message = 'The image uploaded, but its body position could not be saved. Remove the marker and try again.';
          setEmbeddedUploadStatus(message, 'error');
          editorStatus.textContent = message;
          return;
        }

        const bodyResponse = await fetch(pocketBaseEndpoint(`/api/collections/posts/records/${postId}`), {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ body_markdown: postForm.body_markdown.value }),
        });
        const bodyData = await bodyResponse.json();
        if (!bodyResponse.ok || bodyData.body_markdown !== postForm.body_markdown.value) {
          const message = formatPocketBaseError(bodyData, 'The image uploaded, but the body placement could not be saved.');
          setEmbeddedUploadStatus(message, 'error');
          editorStatus.textContent = message;
          return;
        }

        allPosts = allPosts.map((post) => post.id === data.id ? bodyData : post);
        embeddedImagesInput.value = '';
        const message = `Upload successful. ${newImages.length} image${newImages.length === 1 ? '' : 's'} inserted and saved in the post body.`;
        setEmbeddedUploadStatus(message, 'success');
        editorStatus.textContent = message;
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Embedded image upload failed.';
        setEmbeddedUploadStatus(message, 'error');
        editorStatus.textContent = message;
      } finally {
        setBusy(false, '', [uploadEmbeddedImagesBtn, savePostBtn, deletePostBtn]);
      }
    });

    postForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearValidationError();
      const auth = getAuth();
      if (!auth) {
        editorStatus.textContent = 'Please log in first.';
        return;
      }

      const validationErrors = validatePostForm();
      if (validationErrors.length) {
        showValidationErrors(validationErrors);
        return;
      }

      if (postForm.status.value === 'published' && !postForm.published_at.value) {
        postForm.published_at.value = new Date().toISOString().slice(0, 16);
      }

      const postId = postForm.post_id.value;
      const endpoint = postId
        ? pocketBaseEndpoint(`/api/collections/posts/records/${postId}`)
        : pocketBaseEndpoint('/api/collections/posts/records');
      const payload = {
        title: postForm.title.value,
        slug: postForm.slug.value || slugify(postForm.title.value),
        summary: postForm.summary.value,
        body_markdown: postForm.body_markdown.value,
        status: postForm.status.value,
        tags: selectedTags(),
        source_urls: parseList(postForm.source_urls.value),
        linkedin_text: postForm.linkedin_text.value,
        x_text: postForm.x_text.value,
        author: auth.record.id,
      };

      if (postForm.published_at.value) {
        payload.published_at = new Date(postForm.published_at.value).toISOString();
      }

      let body;
      const headers = { 'Content-Type': 'application/json' };

      try {
        setBusy(true, postForm.status.value === 'published' ? 'Publishing post...' : 'Saving post...', [savePostBtn, deletePostBtn, newPostBtn]);

        const coverImage = postForm.cover_image.files[0];
        if (coverImage) {
          payload._cover_image = {
            name: coverImage.name,
            type: coverImage.type,
            data: await fileToBase64(coverImage),
          };
        }

        body = JSON.stringify(payload);

        const response = await fetch(endpoint, {
          method: postId ? 'PATCH' : 'POST',
          headers,
          body,
        });

        const data = await response.json();
        if (!response.ok) {
          editorStatus.textContent = formatPocketBaseError(data, 'Save failed.');
          return;
        }

        postForm.post_id.value = data.id;
        postForm.cover_image.value = '';
        clearValidationError();
        const successMessage = `${data.status === 'published' ? 'Published' : 'Saved'} "${data.title}" successfully.`;
        editorStatus.textContent = successMessage;
        await fetchPosts();
        editorStatus.textContent = successMessage;
      } catch (error) {
        editorStatus.textContent = error instanceof Error ? error.message : 'Save failed.';
      } finally {
        setBusy(false, '', [savePostBtn, deletePostBtn, newPostBtn]);
      }
    });
    }

    loadMorePostsBtn.style.display = 'none';
    if (editorAvailable) {
      updateEditorCounters();
      syncTagQuickButtons();
    }
    refreshAuthState();
  </script>

  <style>
