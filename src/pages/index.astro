---
import BaseLayout from '../layouts/BaseLayout.astro';
import TechEvolution from '../components/TechEvolution.astro';
import { profile } from '../lib/profile.js';
import { getGitHubActivity, getGitHubRepos } from '../lib/github.js';
import { getRecentPostsForHome } from '../lib/pocketbase.js';

const cspNonce = Astro.locals.cspNonce;
let posts: any[] = [];
let repos: any[] = [];
let activity: { total: string; cells: any[]; monthLabels: any[] } = { total: '0', cells: [], monthLabels: [] };
let blogError = '';
let githubError = '';
const profileSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://ixuvo.com/#person',
      name: 'Md Iqbal Hossain Shuvo',
      alternateName: ['Shuvo', 'isuvo'],
      url: 'https://ixuvo.com/',
      jobTitle: 'Engineering Lead',
      hasOccupation: [
        'Engineering Lead',
        'AI SaaS Architect',
        'AI Systems Architect',
        'Senior Systems Developer',
        'Senior Software Developer',
        'Software Developer',
        'Full-Stack Engineer',
        'Software Architect',
        'Platform Engineer',
        'AI Systems Engineer',
      ].map((name) => ({ '@type': 'Occupation', name })),
      knowsAbout: [
        'AI SaaS Architecture',
        'Agentic Systems',
        'AI Workflow Automation',
        'Business Process Automation',
        'Software Architecture',
        'Full-Stack Engineering',
        'Distributed Systems',
        'Cloud-Native Systems',
        'Platform Engineering',
        'DevSecOps',
        'Software Security',
        'Graph Neural Networks',
        'Causal AI',
        'Explainable AI',
      ],
      sameAs: [
        'https://github.com/isuvo',
        'https://www.linkedin.com/in/isuvo/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://ixuvo.com/#website',
      url: 'https://ixuvo.com/',
      name: 'Shuvo',
      alternateName: ['isuvo', 'ixuvo'],
      publisher: { '@id': 'https://ixuvo.com/#person' },
      inLanguage: 'en-CA',
    },
    {
      '@type': 'ProfilePage',
      '@id': 'https://ixuvo.com/#profilepage',
      url: 'https://ixuvo.com/',
      mainEntity: { '@id': 'https://ixuvo.com/#person' },
      isPartOf: { '@id': 'https://ixuvo.com/#website' },
    },
  ],
};

try {
  posts = await getRecentPostsForHome(6);
} catch (error) {
  blogError = error instanceof Error ? error.message : 'Blog database is not ready yet.';
}

try {
  [repos, activity] = await Promise.all([getGitHubRepos(9), getGitHubActivity()]);
} catch (error) {
  githubError = error instanceof Error ? error.message : 'GitHub activity is unavailable right now.';
}
---

<BaseLayout
  title="Shuvo | Engineering Lead, AI Architect & Full-Stack Engineer"
  description="Engineering Lead and AI architect Shuvo builds agentic systems, AI SaaS products, secure cloud-native platforms, and scalable business automation."
  canonical="/"
  jsonLd={profileSchema}
>
  <section class="hero">
    <h1 class="hero-statement">
      <span class="hero-phrase hero-architecting">Architecting</span>
      <span class="hero-phrase hero-agentic">Agentic Systems</span>
    </h1>
    <div class="identity-lines hero-support">
      <div class="identity-primary"><span class="identity-name">Shuvo</span> — Engineering Lead &amp; AI/ML Researcher</div>
      <div class="identity-focus">AI SaaS <span aria-hidden="true">·</span> Automation <span aria-hidden="true">·</span> Agentic Systems</div>
    </div>
    <p class="lead-copy hero-lead">I turn complex ideas into scalable AI products, automated workflows, and measurable business outcomes.</p>
    <div class="hero-actions hero-actions-intro">
      <a class="cta" href="/blog">
        <span>Read Blog</span><span class="cta-icon" aria-hidden="true">&#8594;</span>
      </a>
      <a class="cta cta-secondary cta-download" href={profile.links.resume} target="_blank" rel="noreferrer">
        <span>Download Resume</span><span class="cta-icon" aria-hidden="true">&#8595;</span>
      </a>
    </div>
  </section>

  <section class="section" id="activity">
    <div class="section-head">
      <h2 class="section-title">
        <span class="section-icon"></span>
        GitHub Contributions Across <a href={profile.links.github} target="_blank" rel="noreferrer">@Personal</a> and <a href="https://github.com/shuvo-kage" target="_blank" rel="noreferrer">@Professional</a> Profiles
      </h2>
    </div>
    <div class="activity-shell">
      <p class="helper">{activity.total} contributions in the last year</p>
      <div class="activity-scroll">
        {activity.monthLabels.length ? (
          <div class="activity-months">
            {activity.monthLabels.map((month) => <span style={`grid-column:${month.weekIndex + 1} / span 4`}>{month.label}</span>)}
          </div>
        ) : null}
        <div class="activity-grid">
          {activity.cells.length ? activity.cells.map((cell) => (
            <div class={`activity-cell level-${cell.level}`} title={`${cell.date}: ${cell.count} contributions`}></div>
          )) : (
            <div class="helper">{githubError || 'GitHub activity is loading.'}</div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Profile</h2>
    </div>
    <div class="summary-strip">
      {profile.summaryCards.map((card) => (
        <article class="summary-card">
          <strong>{card.label}</strong>
          <span class="metric-value">{card.metric}</span>
          <p>{card.value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Career Timeline</h2>
    </div>
    <div class="timeline-stack">
      {profile.careerTimeline.map((item) => (
        <article class="timeline-card">
          <div class="timeline-period">{item.period}</div>
          <div class="entry-title">{item.label}</div>
          {item.organization ? (
            <div class="entry-subtitle">
              {item.organizationUrl ? (
                <a href={item.organizationUrl} target="_blank" rel="noreferrer">{item.organization}</a>
              ) : item.organization}
            </div>
          ) : null}
          <p class="timeline-detail">{item.detail}</p>
          <ul class="timeline-points">
            {item.highlights.map((point) => <li>{point}</li>)}
          </ul>
          {item.stack?.length ? (
            <div class="pill-row" style="margin-top:0.8rem;">
              {item.stack.map((tag) => <span class="pill">{tag}</span>)}
            </div>
          ) : null}
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Technology Journey</h2>
    </div>
    <TechEvolution />
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Education and Certifications</h2>
    </div>
    <div class="three-col-list">
      {profile.education.map((item) => (
        <article class="panel">
          <div class="entry-title">{item.school}</div>
          <div class="entry-subtitle">{item.degree}</div>
          {item.location ? <p>{item.location}</p> : null}
          {item.details ? <p style="margin-top:0.7rem;">{item.details}</p> : null}
        </article>
      ))}
      {profile.certifications.map((item) => (
        <article class="panel">
          <div class="entry-title">{item.name}</div>
          <div class="entry-subtitle">{item.issuer}</div>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="projects">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Recent Posts</h2>
    </div>
    <div class="grid three">
      {posts.length ? posts.map((post) => (
        <article class="post-card home-post-card">
          <div class="meta">{post.published_at ? new Date(post.published_at).toLocaleDateString('en-CA') : 'Draft'}</div>
          <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
          <p>{post.summary || 'No summary yet.'}</p>
          {post.legacy_imported ? (
            <p class="legacy-note">Migrated from the original suvoBGD WordPress archive.</p>
          ) : null}
          {post.tags?.length ? (
            <div class="pill-row" style="margin-top:0.5rem;">
              {post.tags.map((tag) => <span class="pill">{tag}</span>)}
            </div>
          ) : null}
        </article>
      )) : (
        <article class="post-card">
          <h3>No published blog entries yet</h3>
          <p>{blogError || 'Use the local writer page to create the first post, then it will appear here and on the dedicated blog page.'}</p>
          <a class="cta" href="/write">Open Writer</a>
        </article>
      )}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Repositories</h2>
    </div>
    <div class="grid three">
      {repos.length ? repos.map((repo) => (
        <article class="post-card repo-card">
          <div class="meta">{repo.language} | Updated {new Date(repo.updated).toLocaleDateString('en-CA')}</div>
          <h3><a href={repo.url} target="_blank" rel="noreferrer">{repo.name}</a></h3>
          <p>{repo.description}</p>
          <div class="repo-actions">
            <a class="repo-action" href={repo.url} target="_blank" rel="noreferrer">Repository</a>
            {repo.homepage ? <a class="repo-action is-primary" href={repo.homepage} target="_blank" rel="noreferrer">Project</a> : null}
          </div>
        </article>
      )) : (
        <article class="post-card">
          <h3>GitHub repositories unavailable</h3>
          <p>{githubError || 'The GitHub API could not be reached.'}</p>
        </article>
      )}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Tools and Practice</h2>
    </div>
    <div class="three-col-list">
      {profile.skills.map((group) => (
        <article class="panel">
          <div class="tool-group-head">
            <span class="tool-icon">{group.icon}</span>
            <div class="entry-title">{group.group}</div>
          </div>
          <div class="pill-row" style="margin-top:0.75rem;">
            {group.items.map((item) => <span class="pill">{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="contact">
    <div class="section-head">
      <h2 class="section-title"><span class="section-icon"></span>Find Me</h2>
    </div>
    <article class="panel find-me-card">
      <div class="find-me-row">
        <strong class="find-me-label">Email</strong>
        <a class="find-me-link find-me-email" href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
      </div>
      <div class="find-me-row">
        <strong class="find-me-label">GitHub</strong>
        <a class="find-me-link" href={profile.contact.github} target="_blank" rel="noopener noreferrer">
          <span>View profile</span><span aria-hidden="true">&#8599;</span>
        </a>
      </div>
      <div class="find-me-row">
        <strong class="find-me-label">LinkedIn</strong>
        <a class="find-me-link" href={profile.contact.linkedin} target="_blank" rel="noopener noreferrer">
          <span>Follow me</span><span aria-hidden="true">&#8599;</span>
        </a>
      </div>
      <div class="find-me-row">
        <strong class="find-me-label">X</strong>
        <div class="find-me-x-action">
          <a
            href="https://x.com/suvobgd?ref_src=twsrc%5Etfw"
            class="twitter-follow-button"
            data-show-count="false"
          >Follow @suvobgd</a>
        </div>
      </div>
    </article>
    <script is:inline nonce={cspNonce} data-cfasync="false" async src="https://platform.x.com/widgets.js" charset="utf-8"></script>
  </section>

  <style>
    .find-me-card {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: center;
      gap: 1rem;
      padding: 1.1rem;
    }

    .find-me-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      min-width: 0;
      padding: 0.2rem;
    }

    .find-me-label {
      color: var(--accent-soft);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .find-me-link {
      width: fit-content;
      max-width: 100%;
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--line-soft);
      color: var(--ink);
      background: rgba(255, 255, 255, 0.03);
      text-decoration: none;
      overflow-wrap: anywhere;
    }

    .find-me-link:hover,
    .find-me-link:focus-visible {
      color: var(--accent-soft);
      border-color: var(--accent);
      outline: none;
    }

    .find-me-email {
      border-color: transparent;
      background: transparent;
      padding-inline: 0;
    }

    .find-me-x-action {
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 0;
      min-height: 28px;
      max-width: 100%;
      overflow: hidden;
    }

    @media (max-width: 980px) {
      .find-me-card {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 620px) {
      .find-me-card {
        grid-template-columns: minmax(0, 1fr);
        gap: 0;
        padding-block: 0.35rem;
      }

      .find-me-row {
        display: grid;
        grid-template-columns: minmax(4.75rem, 0.3fr) minmax(0, 1fr);
        justify-content: stretch;
        gap: 0.75rem;
        padding: 0.75rem 0;
      }

      .find-me-row + .find-me-row {
        border-top: 1px solid var(--line-soft);
      }

      .find-me-link,
      .find-me-x-action {
        justify-self: start;
      }
    }
  </style>
</BaseLayout>
